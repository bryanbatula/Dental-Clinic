{
  "name": "clinic-desktop",
  "version": "1.0.0",
  "description": "Clinic Management System - Desktop Application",
  "main": "main.js",
  "author": "",
  "license": "ISC",
  "scripts": {
    "electron": "electron .",
    "electron-dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux",
    "dist": "npm run build",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.clinic.desktop",
    "productName": "Clinic Management System",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "../src/**/*",
      "../models/**/*",
      "../routes/**/*",
      "../views/**/*",
      "../config/**/*",
      "../assets/**/*",
      "../node_modules/**/*",
      "../package.json"
    ],
    "extraResources": [
      {
        "from": "../scripts",
        "to": "scripts"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../assets/icons/a.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": "dmg",
      "icon": "../assets/icons/a.ico",
      "category": "public.app-category.medical"
    },
    "linux": {
      "target": "AppImage",
      "icon": "../assets/icons/a.ico",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": null
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
} 