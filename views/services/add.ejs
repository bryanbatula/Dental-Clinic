<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add New Service | Clinic Management</title>
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
  <div class="dashboard-wrapper">
    <aside class="dashboard-sidebar">
      <!-- Enhanced User Profile Section -->
      <div class="dashboard-user-profile">
        <div class="user-avatar">
          <i class="fas fa-user-md"></i>
        </div>
        <div class="user-details">
          <h3 class="user-name">Dr. <%= user.username %></h3>
          <p class="user-role">Clinic Administrator</p>
          <div class="user-status">
            <span class="status-indicator active"></span>
            <span class="status-text">Online</span>
          </div>
        </div>
      </div>
      
      <!-- Enhanced Navigation -->
      <nav class="dashboard-nav">
        <div class="nav-section">
          <span class="nav-section-title">Main</span>
          <a href="/dashboard" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-pie"></i>
            </div>
            <span class="nav-text">Dashboard</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Management</span>
          <a href="/clients" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-users"></i>
            </div>
            <span class="nav-text">Clients</span>
          </a>
          <a href="/appointments" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="far fa-calendar-alt"></i>
            </div>
            <span class="nav-text">Appointments</span>
          </a>
          <a href="/appointments/calendar" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-calendar-week"></i>
            </div>
            <span class="nav-text">Calendar</span>
          </a>
          <a href="/treatments" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-procedures"></i>
            </div>
            <span class="nav-text">Treatments</span>
          </a>
          <a href="/services/manage" class="dashboard-nav-item active">
            <div class="nav-icon">
              <i class="fas fa-tooth"></i>
            </div>
            <span class="nav-text">Services</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Tools</span>
          <a href="/reminders" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-bell"></i>
            </div>
            <span class="nav-text">Reminders</span>
          </a>
          <a href="/reports" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-line"></i>
            </div>
            <span class="nav-text">Analytics</span>
          </a>
        </div>
      </nav>
      
      <!-- Enhanced Logout Section -->
      <div class="dashboard-logout">
        <a href="/logout" class="dashboard-logout-btn">
          <i class="fas fa-sign-out-alt"></i>
          <span>Sign Out</span>
        </a>
      </div>
    </aside>

    <main class="dashboard-content">
      <!-- Enhanced Header with Breadcrumb -->
      <header class="dashboard-header">
        <div class="header-content">
          <div class="breadcrumb">
            <span class="breadcrumb-item">Clinic</span>
            <i class="fas fa-chevron-right"></i>
            <a href="/services/manage" class="breadcrumb-item">Services</a>
            <i class="fas fa-chevron-right"></i>
            <span class="breadcrumb-item current">Add Service</span>
          </div>
          <h1 class="dashboard-title">
            <i class="fas fa-plus-circle title-icon"></i>
            Create New Service
          </h1>
          <p class="dashboard-subtitle">Add a new dental service to your treatment catalog</p>
        </div>
        <div class="header-actions">
          <div class="current-time" id="currentTime">
            <i class="far fa-clock"></i>
            <span></span>
          </div>
          <a href="/services/manage" class="dashboard-btn secondary">
            <i class="fas fa-list"></i>
            <span>View Services</span>
          </a>
        </div>
      </header>

      <!-- Alert Section -->
      <% if (typeof error !== 'undefined' && error) { %>
        <section class="alert-section">
          <div class="alert alert-error">
            <i class="fas fa-exclamation-triangle"></i>
            <span><%= error %></span>
          </div>
        </section>
      <% } %>

      <!-- Enhanced Form Section -->
      <section class="form-section">
        <div class="form-wrapper">
          <div class="form-header">
            <h2 class="form-title">
              <i class="fas fa-tooth"></i>
              Service Information
            </h2>
            <p class="form-subtitle">Please fill in all required fields to create a new service</p>
          </div>

          <form action="/services/add" method="POST" class="service-form enhanced" id="serviceForm">
            <!-- Basic Information Section -->
            <div class="form-section-card">
              <div class="form-section-header">
                <h3>
                  <i class="fas fa-info-circle"></i>
                  Basic Information
                </h3>
                <p>Service identification and categorization details</p>
              </div>

              <div class="form-group">
                <label for="name" class="form-label">
                  <i class="fas fa-tag"></i>
                  Service Name <span class="required">*</span>
                </label>
                <input type="text" id="name" name="name" required 
                       value="<%= typeof formData !== 'undefined' ? formData.name : '' %>"
                       placeholder="Enter descriptive service name (e.g., Teeth Cleaning, Root Canal)"
                       class="form-input">
                <div class="form-hint">
                  <i class="fas fa-lightbulb"></i>
                  Use clear, professional names that patients will easily understand
                </div>
              </div>

              <div class="form-group">
                <label for="category" class="form-label">
                  <i class="fas fa-layer-group"></i>
                  Service Category <span class="required">*</span>
                </label>
                <div class="select-wrapper">
                  <select id="category" name="category" required class="form-select">
                    <option value="">Select a service category</option>
                    <option value="General" <%= (typeof formData !== 'undefined' && formData.category === 'General') ? 'selected' : '' %>>
                      🏥 General Dentistry
                    </option>
                    <option value="Cosmetic" <%= (typeof formData !== 'undefined' && formData.category === 'Cosmetic') ? 'selected' : '' %>>
                      ✨ Cosmetic Dentistry
                    </option>
                    <option value="Orthodontics" <%= (typeof formData !== 'undefined' && formData.category === 'Orthodontics') ? 'selected' : '' %>>
                      🦷 Orthodontics
                    </option>
                    <option value="Surgery" <%= (typeof formData !== 'undefined' && formData.category === 'Surgery') ? 'selected' : '' %>>
                      🏥 Oral Surgery
                    </option>
                    <option value="Pediatric" <%= (typeof formData !== 'undefined' && formData.category === 'Pediatric') ? 'selected' : '' %>>
                      👶 Pediatric Dentistry
                    </option>
                    <option value="Emergency" <%= (typeof formData !== 'undefined' && formData.category === 'Emergency') ? 'selected' : '' %>>
                      🚨 Emergency Care
                    </option>
                  </select>
                  <i class="fas fa-chevron-down select-icon"></i>
                </div>
                <div class="form-hint">
                  <i class="fas fa-info-circle"></i>
                  Category helps organize services and improves patient search experience
                </div>
              </div>
            </div>

            <!-- Scheduling & Pricing Section -->
            <div class="form-section-card">
              <div class="form-section-header">
                <h3>
                  <i class="fas fa-calculator"></i>
                  Scheduling & Pricing
                </h3>
                <p>Time allocation and cost structure for this service</p>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="duration" class="form-label">
                    <i class="fas fa-clock"></i>
                    Duration (minutes) <span class="required">*</span>
                  </label>
                  <input type="number" id="duration" name="duration" required min="15" max="480" step="15"
                         value="<%= typeof formData !== 'undefined' ? formData.duration : '30' %>"
                         placeholder="30"
                         class="form-input">
                  <div class="form-hint">
                    <i class="fas fa-info-circle"></i>
                    Standard appointment slot duration (15-480 minutes)
                  </div>
                </div>

                <div class="form-group">
                  <label for="price" class="form-label">
                    <i class="fas fa-dollar-sign"></i>
                    Service Price <span class="required">*</span>
                  </label>
                  <div class="input-with-prefix">
                    <span class="input-prefix">$</span>
                    <input type="number" id="price" name="price" required min="0" step="0.01"
                           value="<%= typeof formData !== 'undefined' ? formData.price : '' %>"
                           placeholder="100.00"
                           class="form-input">
                  </div>
                  <div class="form-hint">
                    <i class="fas fa-info-circle"></i>
                    Base price for this service (insurance adjustments handled separately)
                  </div>
                </div>
              </div>

              <!-- Price Preview -->
              <div class="price-preview">
                <div class="preview-item">
                  <span class="preview-label">Estimated Duration:</span>
                  <span class="preview-value" id="durationPreview">30 minutes</span>
                </div>
                <div class="preview-item">
                  <span class="preview-label">Service Price:</span>
                  <span class="preview-value" id="pricePreview">$100.00</span>
                </div>
              </div>
            </div>

            <!-- Service Description Section -->
            <div class="form-section-card">
              <div class="form-section-header">
                <h3>
                  <i class="fas fa-file-alt"></i>
                  Service Description
                </h3>
                <p>Detailed information about the service and what it includes</p>
              </div>

              <div class="form-group">
                <label for="description" class="form-label">
                  <i class="fas fa-align-left"></i>
                  Description <span class="required">*</span>
                </label>
                <textarea id="description" name="description" rows="5" required
                          placeholder="Provide a comprehensive description of the service including:&#10;• What the service involves&#10;• What's included in the treatment&#10;• Expected outcomes&#10;• Any special preparations needed&#10;• Follow-up care instructions"
                          class="form-textarea"><%= typeof formData !== 'undefined' ? formData.description : '' %></textarea>
                <div class="character-count">
                  <span id="charCount">0</span> characters
                </div>
                <div class="form-hint">
                  <i class="fas fa-lightbulb"></i>
                  A detailed description helps patients understand the value and process of the service
                </div>
              </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions enhanced">
              <button type="submit" class="dashboard-btn primary large" id="submitBtn">
                <i class="fas fa-plus-circle"></i>
                <span>Create Service</span>
                <div class="btn-loading hidden">
                  <i class="fas fa-spinner fa-spin"></i>
                </div>
              </button>
              <a href="/services/manage" class="dashboard-btn secondary large">
                <i class="fas fa-times"></i>
                <span>Cancel</span>
              </a>
            </div>
          </form>
        </div>
      </section>
    </main>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Update current time
      function updateTime() {
        const now = new Date();
        const timeString = now.toLocaleString('en-US', {
          weekday: 'short',
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });
        const timeElement = document.querySelector('#currentTime span');
        if (timeElement) {
          timeElement.textContent = timeString;
        }
      }
      
      updateTime();
      setInterval(updateTime, 60000);

      // Form enhancement and validation
      const form = document.getElementById('serviceForm');
      const submitBtn = document.getElementById('submitBtn');
      const durationInput = document.getElementById('duration');
      const priceInput = document.getElementById('price');
      const descriptionInput = document.getElementById('description');
      const charCount = document.getElementById('charCount');

      // Price and duration preview updates
      function updatePreviews() {
        const duration = durationInput.value || '30';
        const price = priceInput.value || '100.00';
        
        document.getElementById('durationPreview').textContent = `${duration} minutes`;
        document.getElementById('pricePreview').textContent = `$${parseFloat(price).toFixed(2)}`;
      }

      durationInput.addEventListener('input', updatePreviews);
      priceInput.addEventListener('input', updatePreviews);

      // Character count for description
      function updateCharCount() {
        const count = descriptionInput.value.length;
        charCount.textContent = count;
        
        if (count > 500) {
          charCount.style.color = '#e74c3c';
        } else if (count > 400) {
          charCount.style.color = '#f39c12';
        } else {
          charCount.style.color = '#7f8c8d';
        }
      }

      descriptionInput.addEventListener('input', updateCharCount);
      updateCharCount();

      // Form submission with loading state
      form.addEventListener('submit', function(e) {
        submitBtn.classList.add('loading');
        submitBtn.disabled = true;
        
        const btnText = submitBtn.querySelector('span');
        const btnLoading = submitBtn.querySelector('.btn-loading');
        
        btnText.style.opacity = '0';
        btnLoading.classList.remove('hidden');
      });

      // Form validation feedback
      const inputs = form.querySelectorAll('input[required], select[required], textarea[required]');
      inputs.forEach(input => {
        input.addEventListener('blur', function() {
          if (!this.value) {
            this.classList.add('error');
          } else {
            this.classList.remove('error');
          }
        });

        input.addEventListener('input', function() {
          if (this.classList.contains('error') && this.value) {
            this.classList.remove('error');
          }
        });
      });

      // Add entrance animations
      const formCards = document.querySelectorAll('.form-section-card');
      formCards.forEach((card, index) => {
        card.style.animation = `slideInUp 0.6s ease-out ${index * 0.1}s both`;
      });

      document.querySelector('.form-actions').style.animation = 'slideInUp 0.6s ease-out 0.4s both';

      // Initialize previews
      updatePreviews();
    });
  </script>
</body>
</html> 