<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Service | Clinic Management</title>
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
  <div class="dashboard-wrapper">
    <aside class="dashboard-sidebar">
      <!-- Enhanced User Profile Section -->
      <div class="dashboard-user-profile">
        <div class="user-avatar">
          <i class="fas fa-user-md"></i>
        </div>
        <div class="user-details">
          <h3 class="user-name"><%= user.username %></h3>
          <p class="user-role">Clinic Administrator</p>
          <div class="user-status">
            <span class="status-indicator active"></span>
            <span class="status-text">Online</span>
          </div>
        </div>
      </div>
      
      <!-- Enhanced Navigation -->
      <nav class="dashboard-nav">
        <div class="nav-section">
          <span class="nav-section-title">Main</span>
          <a href="/dashboard" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-pie"></i>
            </div>
            <span class="nav-text">Dashboard</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Management</span>
          <a href="/clients" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-users"></i>
            </div>
            <span class="nav-text">Clients</span>
          </a>
          <a href="/appointments" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="far fa-calendar-alt"></i>
            </div>
            <span class="nav-text">Appointments</span>
          </a>
          <a href="/treatments" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-procedures"></i>
            </div>
            <span class="nav-text">Treatments</span>
          </a>
          <a href="/appointments/calendar" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-calendar-week"></i>
            </div>
            <span class="nav-text">Calendar</span>
          </a>
          <a href="/services/manage" class="dashboard-nav-item active">
            <div class="nav-icon">
              <i class="fas fa-tooth"></i>
            </div>
            <span class="nav-text">Services</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Tools</span>
          <a href="/reminders" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-bell"></i>
            </div>
            <span class="nav-text">Reminders</span>
          </a>
          <a href="/reports" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-line"></i>
            </div>
            <span class="nav-text">Analytics</span>
          </a>
        </div>
      </nav>
      
      <!-- Enhanced Logout Section -->
      <div class="dashboard-logout">
        <a href="/logout" class="dashboard-logout-btn">
          <i class="fas fa-sign-out-alt"></i>
          <span>Sign Out</span>
        </a>
      </div>
    </aside>

    <main class="dashboard-content">
      <!-- Enhanced Header with Service Details -->
      <header class="dashboard-header">
        <div class="header-content">
          <div class="breadcrumb">
            <span class="breadcrumb-item">Clinic</span>
            <i class="fas fa-chevron-right"></i>
            <a href="/services/manage" class="breadcrumb-item">Services</a>
            <i class="fas fa-chevron-right"></i>
            <span class="breadcrumb-item current">Edit Service</span>
          </div>
          <div class="service-header-info">
            <div class="service-header-main">
              <h1 class="dashboard-title">
                <i class="fas fa-edit title-icon"></i>
                Edit Service
              </h1>
              <div class="service-header-details">
                <span class="service-name">"<%= service.name %>"</span>
                <span class="service-category category-<%= service.category.toLowerCase() %>">
                  <i class="fas fa-tag"></i>
                  <%= service.category %>
                </span>
              </div>
            </div>
            <div class="service-quick-info">
              <div class="quick-info-item">
                <i class="fas fa-clock"></i>
                <span><%= service.duration %> min</span>
              </div>
              <div class="quick-info-item">
                <i class="fas fa-dollar-sign"></i>
                <span>$<%= parseFloat(service.price).toFixed(2) %></span>
              </div>
              <div class="quick-info-item">
                <i class="fas fa-hashtag"></i>
                <span>ID: <%= service.id %></span>
              </div>
            </div>
          </div>
          <p class="dashboard-subtitle">Update service information and pricing details</p>
        </div>
        <div class="header-actions">
          <div class="current-time" id="currentTime">
            <i class="far fa-clock"></i>
            <span></span>
          </div>
          <a href="/services/manage" class="dashboard-btn secondary">
            <i class="fas fa-list"></i>
            <span>All Services</span>
          </a>
        </div>
      </header>

      <!-- Alert Section -->
      <% if (typeof error !== 'undefined' && error) { %>
        <section class="alert-section">
          <div class="alert alert-error">
            <i class="fas fa-exclamation-triangle"></i>
            <span><%= error %></span>
          </div>
        </section>
      <% } %>

      <!-- Enhanced Form Section -->
      <section class="form-section">
        <div class="form-wrapper">
          <div class="form-header">
            <h2 class="form-title">
              <i class="fas fa-cog"></i>
              Service Configuration
            </h2>
            <p class="form-subtitle">Modify any field below to update the service information</p>
          </div>

          <form action="/services/edit/<%= service.id %>" method="POST" class="service-form enhanced" id="serviceForm">
            <!-- Basic Information Section -->
            <div class="form-section-card">
              <div class="form-section-header">
                <h3>
                  <i class="fas fa-info-circle"></i>
                  Basic Information
                </h3>
                <p>Service identification and categorization details</p>
              </div>

              <div class="form-group">
                <label for="name" class="form-label">
                  <i class="fas fa-tag"></i>
                  Service Name <span class="required">*</span>
                </label>
                <input type="text" id="name" name="name" required 
                       value="<%= typeof formData !== 'undefined' ? formData.name : service.name %>"
                       placeholder="Enter descriptive service name"
                       class="form-input">
                <div class="form-hint">
                  <i class="fas fa-lightbulb"></i>
                  Clear, professional names help patients understand your services
                </div>
              </div>

              <div class="form-group">
                <label for="category" class="form-label">
                  <i class="fas fa-layer-group"></i>
                  Service Category <span class="required">*</span>
                </label>
                <div class="select-wrapper">
                  <select id="category" name="category" required class="form-select">
                    <option value="">Select a service category</option>
                    <option value="General" <%= (typeof formData !== 'undefined' ? formData.category : service.category) === 'General' ? 'selected' : '' %>>
                      🏥 General Dentistry
                    </option>
                    <option value="Cosmetic" <%= (typeof formData !== 'undefined' ? formData.category : service.category) === 'Cosmetic' ? 'selected' : '' %>>
                      ✨ Cosmetic Dentistry
                    </option>
                    <option value="Orthodontics" <%= (typeof formData !== 'undefined' ? formData.category : service.category) === 'Orthodontics' ? 'selected' : '' %>>
                      🦷 Orthodontics
                    </option>
                    <option value="Surgery" <%= (typeof formData !== 'undefined' ? formData.category : service.category) === 'Surgery' ? 'selected' : '' %>>
                      🏥 Oral Surgery
                    </option>
                    <option value="Pediatric" <%= (typeof formData !== 'undefined' ? formData.category : service.category) === 'Pediatric' ? 'selected' : '' %>>
                      👶 Pediatric Dentistry
                    </option>
                    <option value="Emergency" <%= (typeof formData !== 'undefined' ? formData.category : service.category) === 'Emergency' ? 'selected' : '' %>>
                      🚨 Emergency Care
                    </option>
                  </select>
                  <i class="fas fa-chevron-down select-icon"></i>
                </div>
                <div class="form-hint">
                  <i class="fas fa-info-circle"></i>
                  Category affects service organization and patient search results
                </div>
              </div>
            </div>

            <!-- Scheduling & Pricing Section -->
            <div class="form-section-card">
              <div class="form-section-header">
                <h3>
                  <i class="fas fa-calculator"></i>
                  Scheduling & Pricing
                </h3>
                <p>Update time allocation and pricing for this service</p>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="duration" class="form-label">
                    <i class="fas fa-clock"></i>
                    Duration (minutes) <span class="required">*</span>
                  </label>
                  <input type="number" id="duration" name="duration" required min="15" max="480" step="15"
                         value="<%= typeof formData !== 'undefined' ? formData.duration : service.duration %>"
                         placeholder="30"
                         class="form-input">
                  <div class="form-hint">
                    <i class="fas fa-info-circle"></i>
                    Standard appointment slot duration (affects scheduling)
                  </div>
                </div>

                <div class="form-group">
                  <label for="price" class="form-label">
                    <i class="fas fa-dollar-sign"></i>
                    Service Price <span class="required">*</span>
                  </label>
                  <div class="input-with-prefix">
                    <span class="input-prefix">$</span>
                    <input type="number" id="price" name="price" required min="0" step="0.01"
                           value="<%= typeof formData !== 'undefined' ? formData.price : service.price %>"
                           placeholder="100.00"
                           class="form-input">
                  </div>
                  <div class="form-hint">
                    <i class="fas fa-info-circle"></i>
                    Base price for this service (insurance handled separately)
                  </div>
                </div>
              </div>

              <!-- Price Comparison -->
              <div class="price-comparison">
                <div class="comparison-item">
                  <span class="comparison-label">Current:</span>
                  <span class="comparison-value current">
                    <%= service.duration %> min • $<%= parseFloat(service.price).toFixed(2) %>
                  </span>
                </div>
                <div class="comparison-arrow">
                  <i class="fas fa-arrow-right"></i>
                </div>
                <div class="comparison-item">
                  <span class="comparison-label">Updated:</span>
                  <span class="comparison-value updated" id="updatedValues">
                    <%= service.duration %> min • $<%= parseFloat(service.price).toFixed(2) %>
                  </span>
                </div>
              </div>
            </div>

            <!-- Service Description Section -->
            <div class="form-section-card">
              <div class="form-section-header">
                <h3>
                  <i class="fas fa-file-alt"></i>
                  Service Description
                </h3>
                <p>Comprehensive information about the service and treatment details</p>
              </div>

              <div class="form-group">
                <label for="description" class="form-label">
                  <i class="fas fa-align-left"></i>
                  Description <span class="required">*</span>
                </label>
                <textarea id="description" name="description" rows="5" required
                          placeholder="Provide a comprehensive description of the service..."
                          class="form-textarea"><%= typeof formData !== 'undefined' ? formData.description : service.description %></textarea>
                <div class="character-count">
                  <span id="charCount">0</span> characters
                </div>
                <div class="form-hint">
                  <i class="fas fa-lightbulb"></i>
                  A detailed description helps patients understand the value and process
                </div>
              </div>
            </div>

            <!-- Change Summary Section -->
            <div class="form-section-card change-summary">
              <div class="form-section-header">
                <h3>
                  <i class="fas fa-history"></i>
                  Change Summary
                </h3>
                <p>Review your modifications before saving</p>
              </div>

              <div id="changesList" class="changes-list">
                <div class="no-changes">
                  <i class="fas fa-info-circle"></i>
                  <span>No changes detected yet. Modify any field above to see changes.</span>
                </div>
              </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions enhanced">
              <button type="submit" class="dashboard-btn primary large" id="submitBtn" disabled>
                <i class="fas fa-save"></i>
                <span>Update Service</span>
                <div class="btn-loading hidden">
                  <i class="fas fa-spinner fa-spin"></i>
                </div>
              </button>
              <a href="/services/manage" class="dashboard-btn secondary large">
                <i class="fas fa-times"></i>
                <span>Cancel Changes</span>
              </a>
              <button type="button" class="dashboard-btn danger large" id="deleteBtn">
                <i class="fas fa-trash"></i>
                <span>Delete Service</span>
              </button>
            </div>
          </form>
        </div>
      </section>

      <!-- Delete Confirmation Modal -->
      <div id="deleteModal" class="modal-overlay hidden">
        <div class="modal-content">
          <div class="modal-icon">
            <i class="fas fa-exclamation-triangle"></i>
          </div>
          <h3 class="modal-title">Delete Service</h3>
          <p class="modal-message">
            Are you sure you want to delete "<%= service.name %>"? 
            This action cannot be undone and will affect any associated appointments.
          </p>
          <div class="modal-actions">
            <button onclick="hideDeleteModal()" class="modal-btn cancel">Cancel</button>
            <button onclick="confirmDelete()" class="modal-btn confirm">Delete Service</button>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Original service data for comparison
      const originalData = {
        name: '<%= service.name %>',
        category: '<%= service.category %>',
        duration: '<%= service.duration %>',
        price: '<%= service.price %>',
        description: document.getElementById('description').value
      };

      // Update current time
      function updateTime() {
        const now = new Date();
        const timeString = now.toLocaleString('en-US', {
          weekday: 'short',
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });
        const timeElement = document.querySelector('#currentTime span');
        if (timeElement) {
          timeElement.textContent = timeString;
        }
      }
      
      updateTime();
      setInterval(updateTime, 60000);

      // Form elements
      const form = document.getElementById('serviceForm');
      const submitBtn = document.getElementById('submitBtn');
      const deleteBtn = document.getElementById('deleteBtn');
      const nameInput = document.getElementById('name');
      const categoryInput = document.getElementById('category');
      const durationInput = document.getElementById('duration');
      const priceInput = document.getElementById('price');
      const descriptionInput = document.getElementById('description');
      const charCount = document.getElementById('charCount');
      const changesList = document.getElementById('changesList');
      const updatedValues = document.getElementById('updatedValues');

      // Character count for description
      function updateCharCount() {
        const count = descriptionInput.value.length;
        charCount.textContent = count;
        
        if (count > 500) {
          charCount.style.color = '#e74c3c';
        } else if (count > 400) {
          charCount.style.color = '#f39c12';
        } else {
          charCount.style.color = '#7f8c8d';
        }
      }

      // Update comparison display
      function updateComparison() {
        const duration = durationInput.value || originalData.duration;
        const price = priceInput.value || originalData.price;
        updatedValues.textContent = `${duration} min • $${parseFloat(price).toFixed(2)}`;
      }

      // Check for changes and update UI
      function checkChanges() {
        const changes = [];
        
        if (nameInput.value !== originalData.name) {
          changes.push(`Name: "${originalData.name}" → "${nameInput.value}"`);
        }
        
        if (categoryInput.value !== originalData.category) {
          changes.push(`Category: "${originalData.category}" → "${categoryInput.value}"`);
        }
        
        if (durationInput.value !== originalData.duration) {
          changes.push(`Duration: ${originalData.duration} → ${durationInput.value} minutes`);
        }
        
        if (priceInput.value !== originalData.price) {
          changes.push(`Price: $${parseFloat(originalData.price).toFixed(2)} → $${parseFloat(priceInput.value).toFixed(2)}`);
        }
        
        if (descriptionInput.value !== originalData.description) {
          changes.push('Description: Updated');
        }

        // Update changes display
        if (changes.length > 0) {
          changesList.innerHTML = changes.map(change => `
            <div class="change-item">
              <i class="fas fa-edit"></i>
              <span>${change}</span>
            </div>
          `).join('');
          submitBtn.disabled = false;
          submitBtn.classList.remove('disabled');
        } else {
          changesList.innerHTML = `
            <div class="no-changes">
              <i class="fas fa-info-circle"></i>
              <span>No changes detected yet. Modify any field above to see changes.</span>
            </div>
          `;
          submitBtn.disabled = true;
          submitBtn.classList.add('disabled');
        }
      }

      // Event listeners
      [nameInput, categoryInput, durationInput, priceInput, descriptionInput].forEach(input => {
        input.addEventListener('input', function() {
          checkChanges();
          updateComparison();
        });
      });

      descriptionInput.addEventListener('input', updateCharCount);

      // Form submission
      form.addEventListener('submit', function(e) {
        submitBtn.classList.add('loading');
        submitBtn.disabled = true;
        
        const btnText = submitBtn.querySelector('span');
        const btnLoading = submitBtn.querySelector('.btn-loading');
        
        btnText.style.opacity = '0';
        btnLoading.classList.remove('hidden');
      });

      // Delete functionality
      deleteBtn.addEventListener('click', function() {
        document.getElementById('deleteModal').classList.remove('hidden');
      });

      // Initialize
      updateCharCount();
      updateComparison();
      checkChanges();

      // Add entrance animations
      const formCards = document.querySelectorAll('.form-section-card');
      formCards.forEach((card, index) => {
        card.style.animation = `slideInUp 0.6s ease-out ${index * 0.1}s both`;
      });

      document.querySelector('.form-actions').style.animation = 'slideInUp 0.6s ease-out 0.5s both';
    });

    // Modal functions
    function hideDeleteModal() {
      document.getElementById('deleteModal').classList.add('hidden');
    }

    function confirmDelete() {
      // Redirect to delete endpoint
      window.location.href = '/services/delete/<%= service.id %>';
    }

    // Close modal on escape key
    document.addEventListener('keydown', function(event) {
      if (event.key === 'Escape') {
        hideDeleteModal();
      }
    });

    // Close modal on background click
    document.getElementById('deleteModal').addEventListener('click', function(event) {
      if (event.target === this) {
        hideDeleteModal();
      }
    });
  </script>
</body>
</html> 