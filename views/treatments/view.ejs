<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Clinic Management</title>
    <link rel="stylesheet" href="/assets/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <div class="dashboard-wrapper">
        <!-- Dashboard Sidebar -->
        <div class="dashboard-sidebar">
            <div class="dashboard-user-profile">
                <div class="user-avatar">
                    <i class="fas fa-user-md"></i>
                </div>
                <div class="user-details">
                    <h3 class="user-name">Dr. Admin</h3>
                    <p class="user-role">Clinic Administrator</p>
                    <div class="user-status">
                        <div class="status-indicator active"></div>
                        <span class="status-text">Active</span>
                    </div>
                </div>
            </div>

            <nav class="dashboard-nav">
                <div class="nav-section">
                    <span class="nav-section-title">Main</span>
                    <a href="/dashboard" class="dashboard-nav-item">
                        <div class="nav-icon"><i class="fas fa-home"></i></div>
                        <span class="nav-text">Dashboard</span>
                    </a>
                </div>

                <div class="nav-section">
                    <span class="nav-section-title">Management</span>
                    <a href="/clients" class="dashboard-nav-item">
                        <div class="nav-icon"><i class="fas fa-users"></i></div>
                        <span class="nav-text">Clients</span>
                    </a>
                    <a href="/appointments" class="dashboard-nav-item">
                        <div class="nav-icon"><i class="fas fa-calendar-alt"></i></div>
                        <span class="nav-text">Appointments</span>
                    </a>
                    <a href="/treatments" class="dashboard-nav-item active">
                        <div class="nav-icon"><i class="fas fa-tooth"></i></div>
                        <span class="nav-text">Treatments</span>
                    </a>
                    <a href="/services/manage" class="dashboard-nav-item">
                        <div class="nav-icon"><i class="fas fa-cogs"></i></div>
                        <span class="nav-text">Services</span>
                    </a>
                </div>

                <div class="nav-section">
                    <span class="nav-section-title">Tools</span>
                    <a href="/appointments/calendar" class="dashboard-nav-item">
                        <div class="nav-icon"><i class="fas fa-calendar"></i></div>
                        <span class="nav-text">Calendar</span>
                    </a>
                    <a href="/reports/analytics" class="dashboard-nav-item">
                        <div class="nav-icon"><i class="fas fa-chart-bar"></i></div>
                        <span class="nav-text">Analytics</span>
                    </a>
                    <a href="/reminders/manage" class="dashboard-nav-item">
                        <div class="nav-icon"><i class="fas fa-bell"></i></div>
                        <span class="nav-text">Reminders</span>
                    </a>
                </div>
            </nav>

            <div class="dashboard-logout">
                <a href="/auth/logout" class="dashboard-logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                    Logout
                </a>
            </div>
        </div>

        <!-- Dashboard Content -->
        <div class="dashboard-content">
            <!-- Enhanced Header -->
            <div class="dashboard-header">
                <div class="header-content">
                    <div class="breadcrumb">
                        <span class="breadcrumb-item">
                            <a href="/dashboard"><i class="fas fa-home"></i> Dashboard</a>
                        </span>
                        <i class="fas fa-chevron-right"></i>
                        <span class="breadcrumb-item">
                            <a href="/treatments">Treatments</a>
                        </span>
                        <i class="fas fa-chevron-right"></i>
                        <span class="breadcrumb-item current">Treatment Details</span>
                    </div>
                    <h1 class="dashboard-title">
                        <i class="title-icon fas fa-tooth"></i>
                        Treatment Details
                    </h1>
                    <p class="dashboard-subtitle">View and manage treatment record information</p>
                </div>
                <div class="header-actions">
                    <div class="current-time">
                        <i class="fas fa-clock"></i>
                        <span id="currentTime"></span>
                    </div>
                </div>
            </div>

            <!-- Error Alert -->
            <% if (error) { %>
                <div class="alert alert-error animate-slide-in">
                    <i class="fas fa-exclamation-circle"></i>
                    <%= error %>
                </div>
            <% } %>

            <!-- Treatment Details Container -->
            <div class="treatment-details animate-slide-in">
                <!-- Client Profile Section -->
                <div class="client-profile-section">
                    <div class="client-profile-card">
                        <div class="client-header">
                            <div class="client-avatar-large">
                                <%= treatment.client_name.charAt(0).toUpperCase() %>
                            </div>
                            <div class="client-title-section">
                                <h2 class="client-name">
                                    <a href="/clients/view/<%= treatment.client_id %>" class="client-link">
                                        <%= treatment.client_name %>
                                    </a>
                                </h2>
                                <p class="client-id">Client ID: #<%= treatment.client_id %></p>
                                <div class="client-badges">
                                    <div class="status-badge active">
                                        <i class="fas fa-check-circle"></i>
                                        Active Client
                                    </div>
                                </div>
                            </div>
                            <div class="client-stats">
                                <div class="stat-item">
                                    <div class="stat-value"><%= treatment.id %></div>
                                    <div class="stat-label">Treatment ID</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Treatment Information Grid -->
                <div class="client-info-grid">
                    <!-- Treatment Details Card -->
                    <div class="info-card">
                        <div class="info-card-header">
                            <div class="card-icon medical">
                                <i class="fas fa-tooth"></i>
                            </div>
                            <h3>Treatment Information</h3>
                            <div class="card-action">
                                <a href="/treatments/edit/<%= treatment.id %>" class="action-btn small edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                            </div>
                        </div>
                        <div class="info-card-content">
                            <div class="info-item">
                                <div class="info-icon">
                                    <i class="fas fa-calendar-day"></i>
                                </div>
                                <div class="info-details">
                                    <label>Date Performed</label>
                                    <span><%= new Date(treatment.date_performed).toLocaleDateString('en-US', { 
                                        year: 'numeric', 
                                        month: 'long', 
                                        day: 'numeric',
                                        weekday: 'long'
                                    }) %></span>
                                </div>
                            </div>
                            
                            <div class="info-item">
                                <div class="info-icon">
                                    <i class="fas fa-tooth"></i>
                                </div>
                                <div class="info-details">
                                    <label>Tooth Number</label>
                                    <span class="tooth-display"><%= treatment.tooth_number || 'Not specified' %></span>
                                </div>
                            </div>
                            
                            <div class="info-item">
                                <div class="info-icon">
                                    <i class="fas fa-user-md"></i>
                                </div>
                                <div class="info-details">
                                    <label>Performing Dentist</label>
                                    <span><%= treatment.dentist || 'Not specified' %></span>
                                </div>
                            </div>
                            
                            <div class="info-item">
                                <div class="info-icon">
                                    <i class="fas fa-file-medical-alt"></i>
                                </div>
                                <div class="info-details">
                                    <label>Treatment Description</label>
                                    <span class="treatment-description"><%= treatment.description %></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Financial Summary Card -->
                    <div class="info-card">
                        <div class="info-card-header">
                            <div class="card-icon contact">
                                <i class="fas fa-dollar-sign"></i>
                            </div>
                            <h3>Financial Summary</h3>
                            <div class="card-badge <%= treatment.balance > 0 ? 'outstanding' : 'paid' %>">
                                <i class="fas fa-<%= treatment.balance > 0 ? 'exclamation-circle' : 'check-circle' %>"></i>
                                <%= treatment.balance > 0 ? 'Outstanding' : 'Paid' %>
                            </div>
                        </div>
                        <div class="info-card-content">
                            <div class="financial-summary">
                                <div class="financial-item">
                                    <div class="info-icon">
                                        <i class="fas fa-receipt"></i>
                                    </div>
                                    <div class="info-details">
                                        <label>Total Charge</label>
                                        <span class="amount-display charge">$<%= treatment.charge.toFixed(2) %></span>
                                    </div>
                                </div>
                                
                                <div class="financial-item">
                                    <div class="info-icon">
                                        <i class="fas fa-credit-card"></i>
                                    </div>
                                    <div class="info-details">
                                        <label>Amount Paid</label>
                                        <span class="amount-display paid">$<%= treatment.paid.toFixed(2) %></span>
                                    </div>
                                </div>
                                
                                <div class="financial-item">
                                    <div class="info-icon">
                                        <i class="fas fa-balance-scale"></i>
                                    </div>
                                    <div class="info-details">
                                        <label>Outstanding Balance</label>
                                        <span class="amount-display <%= treatment.balance > 0 ? 'has-balance' : 'paid' %>">
                                            $<%= treatment.balance.toFixed(2) %>
                                        </span>
                                    </div>
                                </div>
                                
                                <div class="financial-item">
                                    <div class="info-icon">
                                        <i class="fas fa-info-circle"></i>
                                    </div>
                                    <div class="info-details">
                                        <label>Payment Status</label>
                                        <span class="status-badge enhanced <%= treatment.balance > 0 ? 'pending' : 'completed' %>">
                                            <i class="fas fa-<%= treatment.balance > 0 ? 'clock' : 'check' %>"></i>
                                            <%= treatment.balance > 0 ? 'Outstanding' : 
                                                treatment.balance < 0 ? 'Overpaid' : 'Paid in Full' %>
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- Payment Actions -->
                            <% if (treatment.balance > 0) { %>
                                <div class="payment-actions">
                                    <button onclick="showPaymentForm()" class="dashboard-btn primary">
                                        <i class="fas fa-plus"></i>
                                        Record Payment
                                    </button>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Additional Notes Section -->
                <% if (treatment.notes) { %>
                    <div class="medical-info-section">
                        <div class="section-divider">
                            <div class="divider-text">
                                <i class="fas fa-sticky-note"></i>
                                Additional Notes
                            </div>
                        </div>
                        <div class="medical-cards-grid">
                            <div class="medical-card">
                                <div class="medical-card-header">
                                    <div class="card-icon notes">
                                        <i class="fas fa-sticky-note"></i>
                                    </div>
                                    <h3>Treatment Notes</h3>
                                </div>
                                <div class="medical-card-content">
                                    <div class="medical-text">
                                        <%= treatment.notes.replace(/\n/g, '<br>') %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>

                <!-- Record Information -->
                <div class="medical-info-section">
                    <div class="section-divider">
                        <div class="divider-text">
                            <i class="fas fa-info-circle"></i>
                            Record Information
                        </div>
                    </div>
                    <div class="medical-cards-grid">
                        <div class="medical-card">
                            <div class="medical-card-header">
                                <div class="card-icon personal">
                                    <i class="fas fa-database"></i>
                                </div>
                                <h3>System Information</h3>
                            </div>
                            <div class="medical-card-content">
                                <div class="info-item">
                                    <div class="info-icon">
                                        <i class="fas fa-calendar-plus"></i>
                                    </div>
                                    <div class="info-details">
                                        <label>Record Created</label>
                                        <span><%= new Date(treatment.created_at).toLocaleString('en-US', {
                                            year: 'numeric',
                                            month: 'long',
                                            day: 'numeric',
                                            hour: '2-digit',
                                            minute: '2-digit'
                                        }) %></span>
                                    </div>
                                </div>
                                
                                <div class="info-item">
                                    <div class="info-icon">
                                        <i class="fas fa-hashtag"></i>
                                    </div>
                                    <div class="info-details">
                                        <label>Treatment ID</label>
                                        <span class="copyable" onclick="copyToClipboard('#<%= treatment.id %>')">
                                            #<%= treatment.id %>
                                            <button class="copy-btn">
                                                <i class="fas fa-copy"></i>
                                            </button>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="action-section">
                    <a href="/treatments/edit/<%= treatment.id %>" class="dashboard-btn secondary large">
                        <i class="fas fa-edit"></i>
                        Edit Treatment
                    </a>
                    <a href="/treatments/add?client_id=<%= treatment.client_id %>" class="dashboard-btn primary large">
                        <i class="fas fa-plus"></i>
                        Add Another Treatment
                    </a>
                    <button onclick="confirmDelete()" class="dashboard-btn danger large">
                        <i class="fas fa-trash"></i>
                        Delete Treatment
                    </button>
                    <a href="/treatments" class="dashboard-btn secondary large">
                        <i class="fas fa-arrow-left"></i>
                        Back to Treatments
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Payment Form Modal -->
    <div id="paymentModal" class="modal-overlay hidden">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Record Payment</h3>
                <button class="modal-close" onclick="hidePaymentForm()">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <form method="POST" action="/treatments/payment/<%= treatment.id %>">
                <div class="current-info">
                    <h4>Current Balance Information</h4>
                    <div class="info-grid">
                        <div class="info-item">
                            <span>Total Charge:</span>
                            <span>$<%= treatment.charge.toFixed(2) %></span>
                        </div>
                        <div class="info-item">
                            <span>Amount Paid:</span>
                            <span>$<%= treatment.paid.toFixed(2) %></span>
                        </div>
                        <div class="info-item">
                            <span>Outstanding Balance:</span>
                            <span class="amount <%= treatment.balance > 0 ? 'balance' : 'paid' %>">
                                $<%= treatment.balance.toFixed(2) %>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="amount">Payment Amount: <span class="required">*</span></label>
                    <input type="number" id="amount" name="amount" step="0.01" 
                           min="0.01" max="<%= treatment.balance %>" required
                           placeholder="Enter payment amount">
                    <small>Maximum: $<%= treatment.balance.toFixed(2) %></small>
                </div>
                
                <div class="form-group">
                    <label for="notes">Payment Notes:</label>
                    <textarea id="notes" name="notes" rows="3" 
                              placeholder="Optional payment notes (e.g., payment method, check number, etc.)"></textarea>
                </div>
                
                <% if (treatment.balance > 0) { %>
                    <div class="warning-notice">
                        <i class="fas fa-exclamation-triangle"></i>
                        Please ensure the payment amount is accurate. This action will update the treatment's financial record.
                    </div>
                <% } %>
                
                <div class="modal-actions">
                    <button type="submit" class="modal-btn confirm">
                        <i class="fas fa-credit-card"></i>
                        Record Payment
                    </button>
                    <button type="button" onclick="hidePaymentForm()" class="modal-btn cancel">
                        Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="modal-overlay hidden">
        <div class="modal-content">
            <div class="modal-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h3 class="modal-title">Confirm Delete</h3>
            <p class="modal-message">
                Are you sure you want to delete this treatment record? This action cannot be undone and will permanently remove all associated data.
            </p>
            <div class="modal-actions">
                <form method="POST" action="/treatments/delete/<%= treatment.id %>" style="display: inline;">
                    <button type="submit" class="modal-btn confirm">
                        <i class="fas fa-trash"></i>
                        Yes, Delete
                    </button>
                </form>
                <button onclick="closeDeleteModal()" class="modal-btn cancel">Cancel</button>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast hidden">
        <div class="toast-content">
            <i class="toast-icon"></i>
            <span class="toast-message"></span>
        </div>
    </div>

    <script>
        // Update current time
        function updateTime() {
            const now = new Date();
            const timeString = now.toLocaleTimeString('en-US', {
                hour: '2-digit',
                minute: '2-digit'
            });
            document.getElementById('currentTime').textContent = timeString;
        }

        // Payment form functions
        function showPaymentForm() {
            document.getElementById('paymentModal').classList.remove('hidden');
            document.getElementById('amount').focus();
            // Auto-fill with full balance
            document.getElementById('amount').value = '<%= treatment.balance %>';
        }

        function hidePaymentForm() {
            document.getElementById('paymentModal').classList.add('hidden');
            document.getElementById('paymentModal').querySelector('form').reset();
        }

        // Delete modal functions
        function confirmDelete() {
            document.getElementById('deleteModal').classList.remove('hidden');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
        }

        // Copy to clipboard function
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(function() {
                showToast('Copied to clipboard!', 'success');
            }).catch(function() {
                showToast('Failed to copy', 'error');
            });
        }

        // Toast notification function
        function showToast(message, type = 'info') {
            const toast = document.getElementById('toast');
            const icon = toast.querySelector('.toast-icon');
            const messageEl = toast.querySelector('.toast-message');
            
            // Reset classes
            toast.className = 'toast';
            
            // Set content
            messageEl.textContent = message;
            
            // Set type and icon
            switch(type) {
                case 'success':
                    toast.classList.add('success');
                    icon.className = 'toast-icon fas fa-check-circle';
                    break;
                case 'error':
                    toast.classList.add('error');
                    icon.className = 'toast-icon fas fa-exclamation-circle';
                    break;
                case 'warning':
                    toast.classList.add('warning');
                    icon.className = 'toast-icon fas fa-exclamation-triangle';
                    break;
                default:
                    toast.classList.add('info');
                    icon.className = 'toast-icon fas fa-info-circle';
            }
            
            // Show toast
            toast.classList.add('show');
            
            // Auto hide after 3 seconds
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => {
                    toast.classList.add('hidden');
                }, 300);
            }, 3000);
        }

        // Close modals when clicking outside
        window.onclick = function(event) {
            const paymentModal = document.getElementById('paymentModal');
            const deleteModal = document.getElementById('deleteModal');
            
            if (event.target === paymentModal) {
                hidePaymentForm();
            }
            if (event.target === deleteModal) {
                closeDeleteModal();
            }
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            updateTime();
            setInterval(updateTime, 60000); // Update every minute
            
            // Initialize animations
            setTimeout(() => {
                document.querySelectorAll('.animate-slide-in').forEach((el, index) => {
                    setTimeout(() => {
                        el.style.opacity = '1';
                        el.style.transform = 'translateY(0)';
                    }, index * 100);
                });
            }, 100);
        });

        // Keyboard shortcuts
        document.addEventListener('keydown', function(event) {
            // Escape key to close modals
            if (event.key === 'Escape') {
                hidePaymentForm();
                closeDeleteModal();
            }
            
            // Ctrl/Cmd + E to edit
            if ((event.ctrlKey || event.metaKey) && event.key === 'e') {
                event.preventDefault();
                window.location.href = '/treatments/edit/<%= treatment.id %>';
            }
        });
    </script>
</body>
</html> 