<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Treatment Record | Clinic Management</title>
    <link rel="stylesheet" href="/assets/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <div class="dashboard-wrapper">
        <aside class="dashboard-sidebar">
            <!-- Enhanced User Profile Section -->
            <div class="dashboard-user-profile">
                <div class="user-avatar">
                    <i class="fas fa-user-md"></i>
                </div>
                <div class="user-details">
                    <h3 class="user-name"><%= user.username %></h3>
                    <p class="user-role">Clinic Administrator</p>
                    <div class="user-status">
                        <span class="status-indicator active"></span>
                        <span class="status-text">Online</span>
                    </div>
                </div>
            </div>
            
            <!-- Enhanced Navigation -->
            <nav class="dashboard-nav">
                <div class="nav-section">
                    <span class="nav-section-title">Main</span>
                    <a href="/dashboard" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-chart-pie"></i>
                        </div>
                        <span class="nav-text">Dashboard</span>
                    </a>
                </div>
                
                <div class="nav-section">
                    <span class="nav-section-title">Management</span>
                    <a href="/clients" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-users"></i>
                        </div>
                        <span class="nav-text">Clients</span>
                    </a>
                    <a href="/appointments" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="far fa-calendar-alt"></i>
                        </div>
                        <span class="nav-text">Appointments</span>
                    </a>
                    <a href="/treatments" class="dashboard-nav-item active">
                        <div class="nav-icon">
                            <i class="fas fa-user-injured"></i>
                        </div>
                        <span class="nav-text">Treatments</span>
                    </a>
                    <a href="/appointments/calendar" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-calendar-week"></i>
                        </div>
                        <span class="nav-text">Calendar</span>
                    </a>
                    <a href="/services/manage" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-tooth"></i>
                        </div>
                        <span class="nav-text">Services</span>
                    </a>
                </div>
                
                <div class="nav-section">
                    <span class="nav-section-title">Tools</span>
                    <a href="/reminders" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-bell"></i>
                        </div>
                        <span class="nav-text">Reminders</span>
                    </a>
                    <a href="/reports" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <span class="nav-text">Analytics</span>
                    </a>
                </div>
            </nav>
            
            <!-- Enhanced Logout Section -->
            <div class="dashboard-logout">
                <a href="/logout" class="dashboard-logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Sign Out</span>
                </a>
            </div>
        </aside>

        <main class="dashboard-content">
            <!-- Enhanced Header with Breadcrumb -->
            <header class="dashboard-header">
                <div class="header-content">
                    <div class="breadcrumb">
                        <span class="breadcrumb-item">Clinic</span>
                        <i class="fas fa-chevron-right"></i>
                        <span class="breadcrumb-item">
                            <a href="/treatments" style="color: #6b7280; text-decoration: none;">Treatments</a>
                        </span>
                        <i class="fas fa-chevron-right"></i>
                        <span class="breadcrumb-item current">Edit Treatment</span>
                    </div>
                    <h1 class="dashboard-title">
                        <i class="fas fa-edit title-icon"></i>
                        Edit Treatment Record
                    </h1>
                    <p class="dashboard-subtitle">Update treatment details, procedure information, and billing data</p>
                </div>
                <div class="header-actions">
                    <div class="current-time" id="currentTime">
                        <i class="far fa-clock"></i>
                        <span></span>
                    </div>
                    <a href="/treatments/view/<%= treatment.id %>" class="dashboard-btn">
                        <i class="fas fa-eye"></i>
                        <span>View Treatment</span>
                    </a>
                </div>
            </header>

            <!-- Enhanced Form Section -->
            <section class="form-section">
                <div class="treatment-form-container">

                    <% if (error) { %>
                        <div class="alert alert-error">
                            <i class="fas fa-exclamation-triangle"></i>
                            <span><%= error %></span>
                        </div>
                    <% } %>

                    <form method="POST" class="treatment-registration-form">
                        <!-- Treatment Information Section -->
                        <div class="form-section-card">
                            <div class="section-header">
                                <h2><i class="fas fa-user-injured"></i> Treatment Information</h2>
                            </div>
                
                <div class="form-group">
                    <label for="clientId">Client: <span class="required">*</span></label>
                    <select id="clientId" name="clientId" required>
                        <% clients.forEach(client => { %>
                            <option value="<%= client.id %>" 
                                    <%= treatment.client_id == client.id ? 'selected' : '' %>>
                                <%= client.name %> - <%= client.phone %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                            <div class="form-grid-2">
                                <div class="form-group">
                                    <label for="datePerformed">Date Performed: <span class="required">*</span></label>
                                    <input type="date" id="datePerformed" name="datePerformed" 
                                           value="<%= treatment.date_performed.toISOString().split('T')[0] %>" required>
                                </div>
                                
                                <div class="form-group">
                                    <label for="toothNumber">Tooth Number:</label>
                                    <input type="text" id="toothNumber" name="toothNumber" 
                                           value="<%= treatment.tooth_number || '' %>"
                                           placeholder="e.g., 18, 55, etc." maxlength="20">
                                </div>
                            </div>

                <div class="form-group">
                    <label for="description">Treatment Description:</label>
                    <textarea id="description" name="description" rows="3" 
                              placeholder="Describe the treatment performed..."><%= treatment.description %></textarea>
                </div>

                <div class="form-group">
                    <label for="dentist">Dentist:</label>
                    <input type="text" id="dentist" name="dentist" 
                           value="<%= treatment.dentist || '' %>"
                           placeholder="Name of the dentist">
                </div>
                        </div>

                        <!-- Billing Information Section -->
                        <div class="form-section-card">
                            <div class="section-header">
                                <h2><i class="fas fa-dollar-sign"></i> Billing Information</h2>
                            </div>
                            
                            <div class="form-grid-2">
                                <div class="form-group">
                                    <label for="charge">Treatment Charge: <span class="required">*</span></label>
                                    <input type="number" id="charge" name="charge" step="0.01" min="0" 
                                           value="<%= treatment.charge %>" required
                                           placeholder="0.00">
                                </div>
                                
                                <div class="form-group">
                                    <label for="paid">Amount Paid:</label>
                                    <input type="number" id="paid" name="paid" step="0.01" min="0" 
                                           value="<%= treatment.paid %>"
                                           placeholder="0.00">
                                </div>
                            </div>

                <div class="balance-display">
                    <label>Calculated Balance:</label>
                    <span id="balanceAmount" class="balance-value">$<%= treatment.balance.toFixed(2) %></span>
                </div>

                <div class="form-group">
                    <label for="notes">Additional Notes:</label>
                    <textarea id="notes" name="notes" rows="3" 
                              placeholder="Any additional notes about the treatment or payment..."><%= treatment.notes || '' %></textarea>
                </div>
            </div>

                        <!-- Record Information Section -->
                        <div class="form-section-card">
                            <div class="section-header">
                                <h2><i class="fas fa-info-circle"></i> Record Information</h2>
                            </div>
                            <div class="info-grid">
                                <div class="info-item">
                                    <label>Record ID:</label>
                                    <span>#<%= treatment.id %></span>
                                </div>
                                <div class="info-item">
                                    <label>Created:</label>
                                    <span><%= new Date(treatment.created_at).toLocaleString() %></span>
                                </div>
                                <div class="info-item">
                                    <label>Current Client:</label>
                                    <span><%= treatment.client_name %></span>
                                </div>
                            </div>
                        </div>

                        <!-- Warning for payment changes -->
                        <div class="warning-notice" style="display: none;" id="paymentWarning">
                            <i class="fas fa-exclamation-triangle"></i>
                            <strong>Warning:</strong> Changing the charge or paid amount will recalculate the balance. 
                            Make sure this is intentional before saving.
                        </div>

                        <!-- Form Actions -->
                        <div class="form-actions">
                            <button type="submit" class="dashboard-btn primary large">
                                <i class="fas fa-save"></i>
                                Update Treatment Record
                            </button>
                            <a href="/treatments/view/<%= treatment.id %>" class="dashboard-btn secondary large">
                                <i class="fas fa-times"></i>
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </section>
        </main>
    </div>

    <script>
        const originalCharge = parseFloat('<%= treatment.charge %>');
        const originalPaid = parseFloat('<%= treatment.paid %>');

        // Enhanced functionality
        document.addEventListener('DOMContentLoaded', function() {
            // Update current time
            function updateTime() {
                const now = new Date();
                const timeString = now.toLocaleString('en-US', {
                    weekday: 'short',
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });
                const timeElement = document.querySelector('#currentTime span');
                if (timeElement) {
                    timeElement.textContent = timeString;
                }
            }
            
            updateTime();
            setInterval(updateTime, 60000); // Update every minute

            // Auto-focus first input
            document.getElementById('clientId').focus();
        });

        // Auto-calculate balance
        function calculateBalance() {
            const charge = parseFloat(document.getElementById('charge').value) || 0;
            const paid = parseFloat(document.getElementById('paid').value) || 0;
            const balance = charge - paid;
            
            document.getElementById('balanceAmount').textContent = '$' + balance.toFixed(2);
            document.getElementById('balanceAmount').className = 'balance-value ' + 
                (balance > 0 ? 'has-balance' : balance < 0 ? 'overpaid' : 'paid');

            // Show warning if financial values changed
            const warning = document.getElementById('paymentWarning');
            if (charge !== originalCharge || paid !== originalPaid) {
                warning.style.display = 'block';
            } else {
                warning.style.display = 'none';
            }
        }

        // Add event listeners
        document.getElementById('charge').addEventListener('input', calculateBalance);
        document.getElementById('paid').addEventListener('input', calculateBalance);

        // Calculate initial balance
        calculateBalance();

        // Client selection enhancement
        document.getElementById('clientId').addEventListener('change', function() {
            if (this.value) {
                // Add visual feedback for client selection
                this.style.borderColor = '#10b981';
                this.style.backgroundColor = '#f0fdf4';
            } else {
                this.style.borderColor = '';
                this.style.backgroundColor = '';
            }
        });

        // Enhanced form validation and submission
        document.querySelector('.treatment-registration-form').addEventListener('submit', function(e) {
            const charge = parseFloat(document.getElementById('charge').value) || 0;
            const paid = parseFloat(document.getElementById('paid').value) || 0;
            
            // Check for significant financial changes
            if (Math.abs(charge - originalCharge) > 10 || Math.abs(paid - originalPaid) > 10) {
                if (!confirm('You are making significant changes to the financial amounts. Are you sure you want to continue?')) {
                    e.preventDefault();
                    return;
                }
            }

            // Show loading state
            const submitBtn = document.querySelector('button[type="submit"]');
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Updating...';
            submitBtn.disabled = true;
        });

        // Toast notification function
        function showToast(message, type = 'info') {
            // Create toast element if it doesn't exist
            let toast = document.getElementById('toast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'toast';
                toast.className = 'toast hidden';
                toast.innerHTML = `
                    <div class="toast-content">
                        <div class="toast-icon"><i class="fas fa-info-circle"></i></div>
                        <div class="toast-message"></div>
                    </div>
                `;
                document.body.appendChild(toast);
            }

            const toastMessage = toast.querySelector('.toast-message');
            const toastIcon = toast.querySelector('.toast-icon i');
            
            toastMessage.textContent = message;
            
            // Update icon and styling based on type
            toast.className = `toast show ${type}`;
            if (type === 'success') {
                toastIcon.className = 'fas fa-check-circle';
            } else if (type === 'error') {
                toastIcon.className = 'fas fa-exclamation-circle';
            } else if (type === 'warning') {
                toastIcon.className = 'fas fa-exclamation-triangle';
            } else {
                toastIcon.className = 'fas fa-info-circle';
            }
            
            // Hide toast after 3 seconds
            setTimeout(() => {
                toast.classList.remove('show');
                toast.classList.add('hidden');
            }, 3000);
        }
    </script>
</body>
</html> 