<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Treatment Records | Clinic Management</title>
    <link rel="stylesheet" href="/assets/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <div class="dashboard-wrapper">
        <aside class="dashboard-sidebar">
            <!-- Enhanced User Profile Section -->
            <div class="dashboard-user-profile">
                <div class="user-avatar">
                    <i class="fas fa-user-md"></i>
                </div>
                <div class="user-details">
                    <h3 class="user-name">Dr. <%= user.username %></h3>
                    <p class="user-role">Clinic Administrator</p>
                    <div class="user-status">
                        <span class="status-indicator active"></span>
                        <span class="status-text">Online</span>
                    </div>
                </div>
            </div>
            
            <!-- Enhanced Navigation -->
            <nav class="dashboard-nav">
                <div class="nav-section">
                    <span class="nav-section-title">Main</span>
                    <a href="/dashboard" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-chart-pie"></i>
                        </div>
                        <span class="nav-text">Dashboard</span>
                    </a>
                </div>
                
                <div class="nav-section">
                    <span class="nav-section-title">Management</span>
                    <a href="/clients" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-users"></i>
                        </div>
                        <span class="nav-text">Clients</span>
                    </a>
                    <a href="/appointments" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="far fa-calendar-alt"></i>
                        </div>
                        <span class="nav-text">Appointments</span>
                    </a>
                    <a href="/appointments/calendar" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-calendar-week"></i>
                        </div>
                        <span class="nav-text">Calendar</span>
                    </a>
                    <a href="/treatments" class="dashboard-nav-item active">
                        <div class="nav-icon">
                            <i class="fas fa-user-injured"></i>
                        </div>
                        <span class="nav-text">Treatments</span>
                    </a>
                    <a href="/services/manage" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-tooth"></i>
                        </div>
                        <span class="nav-text">Services</span>
                    </a>
                </div>
                
                <div class="nav-section">
                    <span class="nav-section-title">Tools</span>
                    <a href="/reminders" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-bell"></i>
                        </div>
                        <span class="nav-text">Reminders</span>
                    </a>
                    <a href="/reports" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <span class="nav-text">Analytics</span>
                    </a>
                </div>
            </nav>
            
            <!-- Enhanced Logout Section -->
            <div class="dashboard-logout">
                <a href="/logout" class="dashboard-logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Sign Out</span>
                </a>
            </div>
        </aside>

        <main class="dashboard-content">
            <!-- Enhanced Header with Breadcrumb -->
            <header class="dashboard-header">
                <div class="header-content">
                    <div class="breadcrumb">
                        <span class="breadcrumb-item">Clinic</span>
                        <i class="fas fa-chevron-right"></i>
                        <span class="breadcrumb-item current">Treatment Records</span>
                    </div>
                    <h1 class="dashboard-title">
                        <i class="fas fa-user-injured title-icon"></i>
                        Treatment Records
                    </h1>
                    <p class="dashboard-subtitle">Manage patient treatments, billing, and payment tracking</p>
                </div>
                <div class="header-actions">
                    <div class="search-container">
                        <form class="search-form" method="GET" action="/treatments">
                            <div class="search-input-wrapper">
                                <i class="fas fa-search search-icon"></i>
                                <input 
                                    type="text" 
                                    name="search" 
                                    class="search-input" 
                                    placeholder="Search by client, description, or dentist..." 
                                    value="<%= searchTerm || '' %>"
                                    autocomplete="off"
                                >
                                <% if (searchTerm && searchTerm.trim()) { %>
                                    <a href="/treatments" class="search-clear" title="Clear search">
                                        <i class="fas fa-times"></i>
                                    </a>
                                <% } %>
                            </div>
                            <button type="submit" class="search-btn">
                                <i class="fas fa-search"></i>
                                <span>Search</span>
                            </button>
                        </form>
                    </div>
                    <div class="current-time" id="currentTime">
                        <i class="far fa-clock"></i>
                        <span></span>
                    </div>
                    <a href="/treatments/add" class="dashboard-btn primary">
                        <i class="fas fa-plus"></i>
                        <span>New Treatment</span>
                    </a>
                </div>
            </header>

            <!-- Enhanced Statistics Section -->
            <section class="treatments-stats-section">
                <div class="stats-grid">
                    <div class="stat-card treatments-stat">
                        <div class="stat-icon">
                            <i class="fas fa-user-injured"></i>
                        </div>
                        <div class="stat-content">
                            <div class="stat-value"><%= summary.totalTreatments %></div>
                            <div class="stat-label">Total Treatments</div>
                            <div class="stat-trend">
                                <i class="fas fa-heartbeat"></i>
                                <span>All procedures</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="stat-card revenue-stat">
                        <div class="stat-icon">
                            <i class="fas fa-dollar-sign"></i>
                        </div>
                        <div class="stat-content">
                            <div class="stat-value">$<%= summary.totalCharges.toFixed(2) %></div>
                            <div class="stat-label">Total Revenue</div>
                            <div class="stat-trend">
                                <i class="fas fa-arrow-up"></i>
                                <span>Gross charges</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="stat-card collected-stat">
                        <div class="stat-icon">
                            <i class="fas fa-money-bill-wave"></i>
                        </div>
                        <div class="stat-content">
                            <div class="stat-value">$<%= summary.totalPaid.toFixed(2) %></div>
                            <div class="stat-label">Collected</div>
                            <div class="stat-trend">
                                <i class="fas fa-check-circle"></i>
                                <span>Payments received</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="stat-card outstanding-stat">
                        <div class="stat-icon">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                        <div class="stat-content">
                            <div class="stat-value">$<%= summary.totalBalance.toFixed(2) %></div>
                            <div class="stat-label">Outstanding</div>
                            <div class="stat-trend">
                                <i class="fas fa-clock"></i>
                                <span>Pending payments</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Enhanced Table Section -->
            <section class="treatments-table-section">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="fas fa-table"></i>
                        Treatment History
                    </h2>
                    <p class="section-subtitle">Complete record of all patient treatments and billing</p>
                </div>

                <div class="treatments-table-wrapper">
                    <!-- Enhanced Table Info Bar -->
                    <div class="table-info-bar">
                        <div class="table-stats">
                            <% if (searchTerm && searchTerm.trim()) { %>
                                <span class="search-results">
                                    <i class="fas fa-search"></i>
                                    Search results for "<%= searchTerm %>"
                                </span>
                                <span class="page-info">
                                    Found <%= pagination.totalItems %> treatment<%= pagination.totalItems !== 1 ? 's' : '' %>
                                </span>
                            <% } else { %>
                                <span class="total-count">
                                    <i class="fas fa-user-injured"></i>
                                    Total: <%= pagination.totalItems %> treatments
                                </span>
                                <span class="page-info">
                                    Showing <%= treatments.length > 0 ? ((pagination.currentPage - 1) * pagination.itemsPerPage + 1) : 0 %> 
                                    to <%= Math.min(pagination.currentPage * pagination.itemsPerPage, pagination.totalItems) %> 
                                    of <%= pagination.totalItems %> entries
                                </span>
                            <% } %>
                        </div>
                        <div class="table-actions">
                            <span class="entries-per-page">
                                <i class="fas fa-list"></i>
                                <%= pagination.itemsPerPage %> per page
                            </span>
                        </div>
                    </div>

                    <% if (treatments && treatments.length > 0) { %>
                        <table class="treatments-table enhanced">
                            <thead>
                                <tr>
                                    <th><i class="fas fa-calendar"></i> Date</th>
                                    <th><i class="fas fa-user"></i> Patient</th>
                                    <th><i class="fas fa-tooth"></i> Tooth #</th>
                                    <th><i class="fas fa-clipboard"></i> Treatment</th>
                                    <th><i class="fas fa-user-md"></i> Dentist</th>
                                    <th><i class="fas fa-dollar-sign"></i> Charge</th>
                                    <th><i class="fas fa-money-bill"></i> Paid</th>
                                    <th><i class="fas fa-balance-scale"></i> Balance</th>
                                    <th><i class="fas fa-cogs"></i> Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% treatments.forEach((treatment, index) => { %>
                                    <tr class="treatment-row <%= treatment.balance > 0 ? 'has-balance' : 'paid' %>" style="animation: slideInUp 0.3s ease-out <%= index * 0.05 %>s both;">
                                        <td class="date-cell">
                                            <div class="date-display">
                                                <span class="date-primary"><%= new Date(treatment.date_performed).toLocaleDateString() %></span>
                                                <span class="day-name"><%= new Date(treatment.date_performed).toLocaleDateString('en-US', { weekday: 'short' }) %></span>
                                            </div>
                                        </td>
                                        <td class="client-info">
                                            <div class="client-profile">
                                                <strong class="client-name"><%= treatment.client_name %></strong>
                                            </div>
                                        </td>
                                        <td class="tooth-cell">
                                            <% if (treatment.tooth_number) { %>
                                                <span class="tooth-number">#<%= treatment.tooth_number %></span>
                                            <% } else { %>
                                                <span class="no-data">-</span>
                                            <% } %>
                                        </td>
                                        <td class="description-cell">
                                            <div class="description-text"><%= treatment.description %></div>
                                        </td>
                                        <td class="dentist-cell">
                                            <span class="dentist-name"><%= treatment.dentist || '-' %></span>
                                        </td>
                                        <td class="amount-cell charge">
                                            <div class="amount-display">
                                                <span class="currency">$</span>
                                                <span class="amount"><%= treatment.charge.toFixed(2) %></span>
                                            </div>
                                        </td>
                                        <td class="amount-cell paid">
                                            <div class="amount-display paid">
                                                <span class="currency">$</span>
                                                <span class="amount"><%= treatment.paid.toFixed(2) %></span>
                                            </div>
                                        </td>
                                        <td class="amount-cell balance">
                                            <div class="amount-display <%= treatment.balance > 0 ? 'has-balance' : 'paid' %>">
                                                <span class="currency">$</span>
                                                <span class="amount"><%= treatment.balance.toFixed(2) %></span>
                                            </div>
                                        </td>
                                        <td class="actions-cell">
                                            <div class="action-buttons">
                                                <a href="/treatments/view/<%= treatment.id %>" class="action-btn view" title="View Details">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="/treatments/edit/<%= treatment.id %>" class="action-btn edit" title="Edit Treatment">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <% if (treatment.balance > 0) { %>
                                                    <button type="button" class="action-btn pay" title="Add Payment" onclick="showPaymentModal(<%= treatment.id %>, '<%= treatment.client_name %>', <%= treatment.balance %>)">
                                                        <i class="fas fa-money-bill-wave"></i>
                                                    </button>
                                                <% } %>
                                                <button type="button" class="action-btn delete" title="Delete Treatment" onclick="showDeleteModal(<%= treatment.id %>, '<%= treatment.description %>')">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <div class="no-data-state enhanced">
                            <div class="no-data-animation">
                                <div class="no-data-icon">
                                    <i class="fas fa-user-injured"></i>
                                    <div class="pulse-ring"></div>
                                </div>
                            </div>
                            <div class="no-data-content">
                                <h3>No treatments found</h3>
                                <p>Start tracking patient treatments and build your clinical database.</p>
                                <div class="no-data-actions">
                                    <a href="/treatments/add" class="dashboard-btn primary large">
                                        <i class="fas fa-plus"></i>
                                        Add First Treatment
                                    </a>
                                    <a href="/clients" class="dashboard-btn secondary">
                                        <i class="fas fa-users"></i>
                                        View Clients
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% } %>

                    <!-- Enhanced Pagination Controls -->
                    <% if (pagination.totalPages > 1) { %>
                        <div class="pagination-wrapper">
                            <div class="pagination-info">
                                <span>Page <%= pagination.currentPage %> of <%= pagination.totalPages %></span>
                            </div>
                            <nav class="pagination-nav">
                                <div class="pagination-controls">
                                    <!-- First Page -->
                                    <% if (pagination.currentPage > 1) { %>
                                        <a href="/treatments?page=1<%= searchTerm ? '&search=' + encodeURIComponent(searchTerm) : '' %>" class="pagination-btn first" title="First Page">
                                            <i class="fas fa-angle-double-left"></i>
                                        </a>
                                    <% } else { %>
                                        <span class="pagination-btn first disabled">
                                            <i class="fas fa-angle-double-left"></i>
                                        </span>
                                    <% } %>

                                    <!-- Previous Page -->
                                    <% if (pagination.hasPrev) { %>
                                        <a href="/treatments?page=<%= pagination.currentPage - 1 %><%= searchTerm ? '&search=' + encodeURIComponent(searchTerm) : '' %>" class="pagination-btn prev" title="Previous Page">
                                            <i class="fas fa-angle-left"></i>
                                        </a>
                                    <% } else { %>
                                        <span class="pagination-btn prev disabled">
                                            <i class="fas fa-angle-left"></i>
                                        </span>
                                    <% } %>

                                    <!-- Page Numbers -->
                                    <div class="pagination-numbers">
                                        <% 
                                            let startPage = Math.max(1, pagination.currentPage - 2);
                                            let endPage = Math.min(pagination.totalPages, pagination.currentPage + 2);
                                            
                                            if (endPage - startPage < 4) {
                                                if (startPage === 1) {
                                                    endPage = Math.min(pagination.totalPages, startPage + 4);
                                                } else {
                                                    startPage = Math.max(1, endPage - 4);
                                                }
                                            }
                                        %>
                                        
                                        <% for (let i = startPage; i <= endPage; i++) { %>
                                            <% if (i === pagination.currentPage) { %>
                                                <span class="pagination-btn current"><%= i %></span>
                                            <% } else { %>
                                                <a href="/treatments?page=<%= i %><%= searchTerm ? '&search=' + encodeURIComponent(searchTerm) : '' %>" class="pagination-btn"><%= i %></a>
                                            <% } %>
                                        <% } %>
                                    </div>

                                    <!-- Next Page -->
                                    <% if (pagination.hasNext) { %>
                                        <a href="/treatments?page=<%= pagination.currentPage + 1 %><%= searchTerm ? '&search=' + encodeURIComponent(searchTerm) : '' %>" class="pagination-btn next" title="Next Page">
                                            <i class="fas fa-angle-right"></i>
                                        </a>
                                    <% } else { %>
                                        <span class="pagination-btn next disabled">
                                            <i class="fas fa-angle-right"></i>
                                        </span>
                                    <% } %>

                                    <!-- Last Page -->
                                    <% if (pagination.currentPage < pagination.totalPages) { %>
                                        <a href="/treatments?page=<%= pagination.totalPages %><%= searchTerm ? '&search=' + encodeURIComponent(searchTerm) : '' %>" class="pagination-btn last" title="Last Page">
                                            <i class="fas fa-angle-double-right"></i>
                                        </a>
                                    <% } else { %>
                                        <span class="pagination-btn last disabled">
                                            <i class="fas fa-angle-double-right"></i>
                                        </span>
                                    <% } %>
                                </div>
                            </nav>
                        </div>
                    <% } %>
                </div>
            </section>
        </main>
    </div>

    <!-- Quick Payment Modal -->
    <div id="paymentModal" class="modal-overlay hidden">
        <div class="modal-content">
            <div class="modal-icon">
                <i class="fas fa-money-bill-wave"></i>
            </div>
            <h3 class="modal-title">Add Payment</h3>
            <div class="modal-body">
                <div class="payment-info">
                    <p><strong>Patient:</strong> <span id="paymentPatient"></span></p>
                    <p><strong>Outstanding Balance:</strong> $<span id="paymentBalance"></span></p>
                </div>
                <form id="paymentForm">
                    <div class="form-group">
                        <label for="paymentAmount">Payment Amount</label>
                        <input type="number" id="paymentAmount" step="0.01" min="0" max="" required>
                    </div>
                    <div class="form-group">
                        <label for="paymentNotes">Payment Notes (Optional)</label>
                        <textarea id="paymentNotes" rows="3" placeholder="Payment method, reference number, etc."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-actions">
                <button class="modal-btn cancel" onclick="hidePaymentModal()">Cancel</button>
                <button class="modal-btn confirm" onclick="submitPayment()">Process Payment</button>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="modal-overlay hidden">
        <div class="modal-content">
            <div class="modal-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h3 class="modal-title">Delete Treatment</h3>
            <p class="modal-message">
                Are you sure you want to delete this treatment record? This action cannot be undone.
            </p>
            <div class="modal-actions">
                <button class="modal-btn cancel" onclick="hideDeleteModal()">Cancel</button>
                <button class="modal-btn confirm" onclick="confirmDelete()">Delete Treatment</button>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast hidden">
        <div class="toast-content">
            <div class="toast-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="toast-message"></div>
        </div>
    </div>

    <script>
        let currentTreatmentId = null;
        let currentDeleteId = null;

        // Enhanced functionality
        document.addEventListener('DOMContentLoaded', function() {
            // Update current time
            function updateTime() {
                const now = new Date();
                const timeString = now.toLocaleString('en-US', {
                    weekday: 'short',
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });
                const timeElement = document.querySelector('#currentTime span');
                if (timeElement) {
                    timeElement.textContent = timeString;
                }
            }
            
            updateTime();
            setInterval(updateTime, 60000); // Update every minute
        });

        // Payment Modal Functions
        function showPaymentModal(treatmentId, patientName, balance) {
            currentTreatmentId = treatmentId;
            document.getElementById('paymentPatient').textContent = patientName;
            document.getElementById('paymentBalance').textContent = balance.toFixed(2);
            document.getElementById('paymentAmount').max = balance;
            document.getElementById('paymentAmount').value = balance;
            document.getElementById('paymentModal').classList.remove('hidden');
        }

        function hidePaymentModal() {
            document.getElementById('paymentModal').classList.add('hidden');
            document.getElementById('paymentForm').reset();
            currentTreatmentId = null;
        }

        function submitPayment() {
            const amount = document.getElementById('paymentAmount').value;
            const notes = document.getElementById('paymentNotes').value;

            if (!amount || amount <= 0) {
                showToast('Please enter a valid payment amount', 'error');
                return;
            }

            // Submit payment
            fetch(`/treatments/payment/${currentTreatmentId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ amount, notes })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('Payment processed successfully', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showToast(data.message || 'Payment processing failed', 'error');
                }
            })
            .catch(error => {
                showToast('Error processing payment', 'error');
            });

            hidePaymentModal();
        }

        // Delete Modal Functions
        function showDeleteModal(treatmentId, description) {
            currentDeleteId = treatmentId;
            document.querySelector('#deleteModal .modal-message').innerHTML = 
                `Are you sure you want to delete the treatment "${description}"? This action cannot be undone.`;
            document.getElementById('deleteModal').classList.remove('hidden');
        }

        function hideDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
            currentDeleteId = null;
        }

        function confirmDelete() {
            if (!currentDeleteId) return;

            fetch(`/treatments/delete/${currentDeleteId}`, {
                method: 'POST'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('Treatment deleted successfully', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showToast(data.message || 'Failed to delete treatment', 'error');
                }
            })
            .catch(error => {
                showToast('Error deleting treatment', 'error');
            });

            hideDeleteModal();
        }

        // Toast Notification Function
        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            const toastMessage = toast.querySelector('.toast-message');
            const toastIcon = toast.querySelector('.toast-icon i');
            
            toastMessage.textContent = message;
            
            // Update icon and styling based on type
            toast.className = `toast show ${type}`;
            if (type === 'success') {
                toastIcon.className = 'fas fa-check-circle';
            } else if (type === 'error') {
                toastIcon.className = 'fas fa-exclamation-circle';
            } else if (type === 'warning') {
                toastIcon.className = 'fas fa-exclamation-triangle';
            }
            
            // Hide toast after 3 seconds
            setTimeout(() => {
                toast.classList.remove('show');
                toast.classList.add('hidden');
            }, 3000);
        }

        // Click outside modal to close
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('modal-overlay')) {
                hidePaymentModal();
                hideDeleteModal();
            }
        });
    </script>
</body>
</html> 