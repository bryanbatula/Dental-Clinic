<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Treatment Record | Clinic Management</title>
    <link rel="stylesheet" href="/assets/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        /* Searchable Select Styles */
        .searchable-select-container {
            position: relative;
            width: 100%;
        }

        .searchable-select-input {
            width: 100%;
            padding: 12px 40px 12px 16px;
            border: 2px solid #e5e7eb;
            border-radius: 8px;
            font-size: 14px;
            background: white;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .searchable-select-input:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

        .searchable-select-arrow {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #6b7280;
            pointer-events: none;
            transition: transform 0.2s ease;
        }

        .searchable-select-container.open .searchable-select-arrow {
            transform: translateY(-50%) rotate(180deg);
        }

        .searchable-select-dropdown {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: white;
            border: 2px solid #e5e7eb;
            border-top: none;
            border-radius: 0 0 8px 8px;
            max-height: 200px;
            overflow-y: auto;
            z-index: 1000;
            display: none;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .searchable-select-container.open .searchable-select-dropdown {
            display: block;
        }

        .dropdown-option {
            padding: 12px 16px;
            cursor: pointer;
            transition: background-color 0.2s ease;
            border-bottom: 1px solid #f3f4f6;
        }

        .dropdown-option:last-child {
            border-bottom: none;
        }

        .dropdown-option:hover {
            background-color: #f9fafb;
        }

        .dropdown-option.selected {
            background-color: #eff6ff;
            color: #1d4ed8;
        }

        .dropdown-option.hidden {
            display: none;
        }

        .client-info {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .client-name {
            font-weight: 500;
            color: #111827;
        }

        .client-phone {
            font-size: 12px;
            color: #6b7280;
        }

        .no-results {
            padding: 12px 16px;
            text-align: center;
            color: #6b7280;
            font-style: italic;
        }
    </style>
</head>
<body>
    <div class="dashboard-wrapper">
        <aside class="dashboard-sidebar">
            <!-- Enhanced User Profile Section -->
            <div class="dashboard-user-profile">
                <div class="user-avatar">
                    <i class="fas fa-user-md"></i>
                </div>
                <div class="user-details">
                    <h3 class="user-name"><%= user.username %></h3>
                    <p class="user-role">Clinic Administrator</p>
                    <div class="user-status">
                        <span class="status-indicator active"></span>
                        <span class="status-text">Online</span>
                    </div>
                </div>
            </div>
            
            <!-- Enhanced Navigation -->
            <nav class="dashboard-nav">
                <div class="nav-section">
                    <span class="nav-section-title">Main</span>
                    <a href="/dashboard" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-chart-pie"></i>
                        </div>
                        <span class="nav-text">Dashboard</span>
                    </a>
                </div>
                
                <div class="nav-section">
                    <span class="nav-section-title">Management</span>
                    <a href="/clients" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-users"></i>
                        </div>
                        <span class="nav-text">Clients</span>
                    </a>
                    <a href="/appointments" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="far fa-calendar-alt"></i>
                        </div>
                        <span class="nav-text">Appointments</span>
                    </a>
                    <a href="/treatments" class="dashboard-nav-item active">
                        <div class="nav-icon">
                            <i class="fas fa-user-injured"></i>
                        </div>
                        <span class="nav-text">Treatments</span>
                    </a>
                    <a href="/appointments/calendar" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-calendar-week"></i>
                        </div>
                        <span class="nav-text">Calendar</span>
                    </a>
                    <a href="/services/manage" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-tooth"></i>
                        </div>
                        <span class="nav-text">Services</span>
                    </a>
                </div>
                
                <div class="nav-section">
                    <span class="nav-section-title">Tools</span>
                    <a href="/reminders" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-bell"></i>
                        </div>
                        <span class="nav-text">Reminders</span>
                    </a>
                    <a href="/reports" class="dashboard-nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <span class="nav-text">Analytics</span>
                    </a>
                </div>
            </nav>
            
            <!-- Enhanced Logout Section -->
            <div class="dashboard-logout">
                <a href="/logout" class="dashboard-logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Sign Out</span>
                </a>
            </div>
        </aside>

        <main class="dashboard-content">
            <!-- Enhanced Header with Breadcrumb -->
            <header class="dashboard-header">
                <div class="header-content">
                    <div class="breadcrumb">
                        <span class="breadcrumb-item">Clinic</span>
                        <i class="fas fa-chevron-right"></i>
                        <span class="breadcrumb-item">
                            <a href="/treatments" style="color: #6b7280; text-decoration: none;">Treatments</a>
                        </span>
                        <i class="fas fa-chevron-right"></i>
                        <span class="breadcrumb-item current">Add New Treatment</span>
                    </div>
                    <h1 class="dashboard-title">
                        <i class="fas fa-plus title-icon"></i>
                        New Treatment Record
                    </h1>
                    <p class="dashboard-subtitle">Record patient treatment, procedure details, and billing information</p>
                </div>
                <div class="header-actions">
                    <div class="current-time" id="currentTime">
                        <i class="far fa-clock"></i>
                        <span></span>
                    </div>
                    <a href="/treatments" class="dashboard-btn">
                        <i class="fas fa-arrow-left"></i>
                        <span>Back to Treatments</span>
                    </a>
                </div>
            </header>

            <!-- Enhanced Form Section -->
            <section class="form-section">
                <div class="treatment-form-container">
                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="alert alert-error">
                            <i class="fas fa-exclamation-triangle"></i>
                            <span><%= error %></span>
                        </div>
                    <% } %>
                    
                    <form class="treatment-registration-form" action="/treatments/add" method="POST">
                        
                        <!-- Treatment Information Section -->
                        <div class="form-section-card">
                            <div class="section-header">
                                <h2><i class="fas fa-user-injured"></i> Treatment Information</h2>
                            </div>
                            
                            <div class="form-group">
                                <label for="clientId">Client: <span class="required">*</span></label>
                                <div class="searchable-select-container">
                                    <input type="text" id="clientSearch" class="searchable-select-input" 
                                           placeholder="Search for a client..." autocomplete="off">
                                    <div class="searchable-select-dropdown" id="clientDropdown">
                                        <div class="dropdown-option" data-value="">Select a client...</div>
                                        <% clients.forEach(client => { %>
                                            <div class="dropdown-option" data-value="<%= client.id %>" 
                                                 data-name="<%= client.name %>" data-phone="<%= client.phone || '' %>"
                                                 <%= formData && formData.clientId == client.id ? 'data-selected="true"' : '' %>>
                                                <div class="client-info">
                                                    <div class="client-name"><%= client.name %></div>
                                                    <div class="client-phone"><%= client.phone || 'No phone' %></div>
                                                </div>
                                            </div>
                                        <% }); %>
                                    </div>
                                    <input type="hidden" id="clientId" name="clientId" required>
                                    <i class="fas fa-chevron-down searchable-select-arrow"></i>
                                </div>
                            </div>

                            <div class="form-grid-2">
                                                <div class="form-group">
                  <label for="datePerformed">Date Performed: <span class="required">*</span></label>
                  <input type="date" id="datePerformed" name="datePerformed" 
                         value="<%= formData && formData.datePerformed ? formData.datePerformed : new Date().toISOString().split('T')[0] %>" required>
                </div>
                
                <div class="form-group">
                  <label for="toothNumber">Tooth Number:</label>
                  <input type="text" id="toothNumber" name="toothNumber" 
                         value="<%= formData ? formData.toothNumber || '' : '' %>"
                         placeholder="e.g., 18, 55, etc." maxlength="20">
                </div>
                            </div>

                            <div class="form-group">
                                <label for="description">Treatment Description:</label>
                                <textarea id="description" name="description" rows="4" 
                                          placeholder="Describe the treatment performed..."><%= formData ? formData.description || '' : '' %></textarea>
                            </div>

                            <div class="form-group">
                                <label for="dentist">Dentist:</label>
                                <input type="text" id="dentist" name="dentist" 
                                       value="<%= formData ? formData.dentist || '' : '' %>"
                                       placeholder="Name of the dentist">
                            </div>
                        </div>

                        <!-- Billing Information Section -->
                        <div class="form-section-card">
                            <div class="section-header">
                                <h2><i class="fas fa-dollar-sign"></i> Billing Information</h2>
                            </div>
                            
                            <div class="form-grid-2">
                                <div class="form-group">
                                    <label for="charge">Treatment Charge: <span class="required">*</span></label>
                                    <input type="number" id="charge" name="charge" step="0.01" min="0" 
                                           value="<%= formData ? formData.charge || '' : '' %>" required
                                           placeholder="0.00">
                                </div>
                                
                                <div class="form-group">
                                    <label for="paid">Amount Paid:</label>
                                    <input type="number" id="paid" name="paid" step="0.01" min="0" 
                                           value="<%= formData ? formData.paid || '0' : '0' %>"
                                           placeholder="0.00">
                                </div>
                            </div>

                            <div class="balance-display">
                                <label>Calculated Balance:</label>
                                <span id="balanceAmount" class="balance-value">$0.00</span>
                            </div>

                            <div class="form-group">
                                <label for="notes">Additional Notes:</label>
                                <textarea id="notes" name="notes" rows="3" 
                                          placeholder="Any additional notes about the treatment or payment..."><%= formData ? formData.notes || '' : '' %></textarea>
                            </div>
                        </div>

                        <!-- Form Actions -->
                        <div class="form-actions">
                            <button type="submit" class="dashboard-btn primary large">
                                <i class="fas fa-save"></i>
                                Save Treatment Record
                            </button>
                            <a href="/treatments" class="dashboard-btn secondary large">
                                <i class="fas fa-times"></i>
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </section>
        </main>
    </div>

    <script>
        // Enhanced functionality
        document.addEventListener('DOMContentLoaded', function() {
            // Update current time
            function updateTime() {
                const now = new Date();
                const timeString = now.toLocaleString('en-US', {
                    weekday: 'short',
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });
                const timeElement = document.querySelector('#currentTime span');
                if (timeElement) {
                    timeElement.textContent = timeString;
                }
            }
            
            updateTime();
            setInterval(updateTime, 60000); // Update every minute

            // Initialize searchable select
            initializeSearchableSelect();
        });

        // Auto-calculate balance
        function calculateBalance() {
            const charge = parseFloat(document.getElementById('charge').value) || 0;
            const paid = parseFloat(document.getElementById('paid').value) || 0;
            const balance = charge - paid;
            
            document.getElementById('balanceAmount').textContent = '$' + balance.toFixed(2);
            document.getElementById('balanceAmount').className = 'balance-value ' + 
                (balance > 0 ? 'has-balance' : balance < 0 ? 'overpaid' : 'paid');
        }

        // Add event listeners
        document.getElementById('charge').addEventListener('input', calculateBalance);
        document.getElementById('paid').addEventListener('input', calculateBalance);

        // Calculate initial balance
        calculateBalance();

        // Searchable Select Functionality
        function initializeSearchableSelect() {
            const container = document.querySelector('.searchable-select-container');
            const input = document.getElementById('clientSearch');
            const dropdown = document.getElementById('clientDropdown');
            const hiddenInput = document.getElementById('clientId');
            const options = dropdown.querySelectorAll('.dropdown-option');
            
            let isOpen = false;
            
            // Check for pre-selected value
            const preSelected = dropdown.querySelector('[data-selected="true"]');
            if (preSelected) {
                const clientName = preSelected.dataset.name;
                const clientPhone = preSelected.dataset.phone;
                input.value = `${clientName} - ${clientPhone}`;
                hiddenInput.value = preSelected.dataset.value;
                preSelected.classList.add('selected');
            }
            
            // Toggle dropdown
            function toggleDropdown() {
                isOpen = !isOpen;
                container.classList.toggle('open', isOpen);
                if (isOpen) {
                    input.focus();
                    filterOptions('');
                }
            }
            
            // Close dropdown
            function closeDropdown() {
                isOpen = false;
                container.classList.remove('open');
            }
            
            // Filter options based on search
            function filterOptions(searchTerm) {
                const term = searchTerm.toLowerCase();
                let hasVisibleOptions = false;
                
                options.forEach(option => {
                    if (option.dataset.value === '') {
                        option.classList.toggle('hidden', term !== '');
                        if (term === '') hasVisibleOptions = true;
                        return;
                    }
                    
                    const name = option.dataset.name.toLowerCase();
                    const phone = option.dataset.phone.toLowerCase();
                    const matches = name.includes(term) || phone.includes(term);
                    
                    option.classList.toggle('hidden', !matches);
                    if (matches) hasVisibleOptions = true;
                });
                
                // Show no results message
                let noResultsMsg = dropdown.querySelector('.no-results');
                if (!hasVisibleOptions && term !== '') {
                    if (!noResultsMsg) {
                        noResultsMsg = document.createElement('div');
                        noResultsMsg.className = 'no-results';
                        noResultsMsg.textContent = 'No clients found';
                        dropdown.appendChild(noResultsMsg);
                    }
                    noResultsMsg.style.display = 'block';
                } else if (noResultsMsg) {
                    noResultsMsg.style.display = 'none';
                }
            }
            
            // Select option
            function selectOption(option) {
                // Clear previous selection
                options.forEach(opt => opt.classList.remove('selected'));
                
                if (option.dataset.value === '') {
                    input.value = '';
                    hiddenInput.value = '';
                } else {
                    const clientName = option.dataset.name;
                    const clientPhone = option.dataset.phone;
                    input.value = `${clientName} - ${clientPhone}`;
                    hiddenInput.value = option.dataset.value;
                    option.classList.add('selected');
                }
                
                closeDropdown();
            }
            
            // Event listeners
            input.addEventListener('click', toggleDropdown);
            input.addEventListener('input', (e) => {
                if (!isOpen) toggleDropdown();
                filterOptions(e.target.value);
            });
            
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') {
                    closeDropdown();
                } else if (e.key === 'ArrowDown' && isOpen) {
                    e.preventDefault();
                    const visibleOptions = Array.from(options).filter(opt => !opt.classList.contains('hidden'));
                    if (visibleOptions.length > 0) {
                        visibleOptions[0].focus();
                    }
                }
            });
            
            // Option click handlers
            options.forEach(option => {
                option.addEventListener('click', () => selectOption(option));
                option.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        selectOption(option);
                    }
                });
                option.setAttribute('tabindex', '0');
            });
            
            // Close dropdown when clicking outside
            document.addEventListener('click', (e) => {
                if (!container.contains(e.target)) {
                    closeDropdown();
                }
            });
            
            // Focus the search input initially
            input.focus();
        }

        // Form validation enhancement
        document.querySelector('.treatment-registration-form').addEventListener('submit', function(e) {
            const clientId = document.getElementById('clientId').value;
            const charge = document.getElementById('charge').value;

            if (!clientId) {
                e.preventDefault();
                document.getElementById('clientSearch').focus();
                showToast('Please select a client', 'error');
                return;
            }

            if (!charge || parseFloat(charge) < 0) {
                e.preventDefault();
                document.getElementById('charge').focus();
                showToast('Please enter a valid treatment charge', 'error');
                return;
            }

            // Show loading state
            const submitBtn = document.querySelector('button[type="submit"]');
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
            submitBtn.disabled = true;
        });

        // Toast notification function
        function showToast(message, type = 'info') {
            // Create toast element if it doesn't exist
            let toast = document.getElementById('toast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'toast';
                toast.className = 'toast hidden';
                toast.innerHTML = `
                    <div class="toast-content">
                        <div class="toast-icon"><i class="fas fa-info-circle"></i></div>
                        <div class="toast-message"></div>
                    </div>
                `;
                document.body.appendChild(toast);
            }

            const toastMessage = toast.querySelector('.toast-message');
            const toastIcon = toast.querySelector('.toast-icon i');
            
            toastMessage.textContent = message;
            
            // Update icon and styling based on type
            toast.className = `toast show ${type}`;
            if (type === 'success') {
                toastIcon.className = 'fas fa-check-circle';
            } else if (type === 'error') {
                toastIcon.className = 'fas fa-exclamation-circle';
            } else if (type === 'warning') {
                toastIcon.className = 'fas fa-exclamation-triangle';
            } else {
                toastIcon.className = 'fas fa-info-circle';
            }
            
            // Hide toast after 3 seconds
            setTimeout(() => {
                toast.classList.remove('show');
                toast.classList.add('hidden');
            }, 3000);
        }
    </script>
</body>
</html> 