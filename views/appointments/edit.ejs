<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Appointment | Clinic Management</title>
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
  <div class="dashboard-wrapper">
    <aside class="dashboard-sidebar">
      <!-- Enhanced User Profile Section -->
      <div class="dashboard-user-profile">
        <div class="user-avatar">
          <i class="fas fa-user-md"></i>
        </div>
        <div class="user-details">
          <h3 class="user-name"><%= user.username %></h3>
          <p class="user-role">Clinic Administrator</p>
          <div class="user-status">
            <span class="status-indicator active"></span>
            <span class="status-text">Online</span>
          </div>
        </div>
      </div>
      
      <!-- Enhanced Navigation -->
      <nav class="dashboard-nav">
        <div class="nav-section">
          <span class="nav-section-title">Main</span>
          <a href="/dashboard" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-pie"></i>
            </div>
            <span class="nav-text">Dashboard</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Management</span>
          <a href="/clients" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-users"></i>
            </div>
            <span class="nav-text">Clients</span>
          </a>
          <a href="/appointments" class="dashboard-nav-item active">
            <div class="nav-icon">
              <i class="far fa-calendar-alt"></i>
            </div>
            <span class="nav-text">Appointments</span>
          </a>
          <a href="/treatments" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-procedures"></i>
            </div>
            <span class="nav-text">Treatments</span>
          </a>
          <a href="/appointments/calendar" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-calendar-week"></i>
            </div>
            <span class="nav-text">Calendar</span>
          </a>
          <a href="/services/manage" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-tooth"></i>
            </div>
            <span class="nav-text">Services</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Tools</span>
          <a href="/reminders" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-bell"></i>
            </div>
            <span class="nav-text">Reminders</span>
          </a>
          <a href="/reports" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-line"></i>
            </div>
            <span class="nav-text">Analytics</span>
          </a>
        </div>
      </nav>
      
      <!-- Enhanced Logout Section -->
      <div class="dashboard-logout">
        <a href="/logout" class="dashboard-logout-btn">
          <i class="fas fa-sign-out-alt"></i>
          <span>Sign Out</span>
        </a>
      </div>
    </aside>

    <main class="dashboard-content">
      <!-- Enhanced Header with Breadcrumb -->
      <header class="dashboard-header">
        <div class="header-content">
          <div class="breadcrumb">
            <span class="breadcrumb-item">Clinic</span>
            <i class="fas fa-chevron-right"></i>
            <span class="breadcrumb-item">
              <a href="/appointments" style="color: #6b7280; text-decoration: none;">Appointments</a>
            </span>
            <i class="fas fa-chevron-right"></i>
            <span class="breadcrumb-item current">Edit Appointment</span>
          </div>
          <h1 class="dashboard-title">
            <i class="fas fa-calendar-edit title-icon"></i>
            Edit Appointment
          </h1>
          <p class="dashboard-subtitle">Update appointment details and scheduling information</p>
        </div>
        <div class="header-actions">
          <div class="current-time" id="currentTime">
            <i class="far fa-clock"></i>
            <span></span>
          </div>
          <a href="/appointments/calendar" class="dashboard-btn secondary">
            <i class="fas fa-calendar-week"></i>
            <span>Calendar View</span>
          </a>
          <a href="/appointments" class="dashboard-btn">
            <i class="fas fa-arrow-left"></i>
            <span>Back to Appointments</span>
          </a>
        </div>
      </header>

      <!-- Enhanced Form Section -->
      <section class="form-section">
        <div class="form-container">
          <div class="form-header">
            <div class="appointment-status-icon">
              <i class="fas fa-<%= appointment.status.toLowerCase() === 'completed' ? 'check' : appointment.status.toLowerCase() === 'scheduled' ? 'clock' : appointment.status.toLowerCase() === 'confirmed' ? 'check-double' : 'times' %>"></i>
            </div>
            <div class="form-title-section">
              <h2>Editing Appointment #<%= appointment.id %></h2>
              <p>
                <strong><%= appointment.client_name || 'Patient' %></strong> • 
                <%= new Date(appointment.appointment_time).toLocaleDateString('en-US', { 
                  year: 'numeric', 
                  month: 'long', 
                  day: 'numeric',
                  hour: '2-digit',
                  minute: '2-digit'
                }) %>
              </p>
            </div>
          </div>

          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error">
              <i class="fas fa-exclamation-triangle"></i>
              <span><%= error %></span>
            </div>
          <% } %>
          
          <form class="enhanced-form" method="POST" action="/appointments/edit/<%= appointment.id %>">
            <div class="form-grid">
              <!-- Patient & Service Information -->
              <div class="form-section-group">
                <h3 class="section-group-title">
                  <i class="fas fa-user-md"></i>
                  Patient & Service
                </h3>
                
                <div class="form-group">
                  <label for="client">
                    <i class="fas fa-user"></i>
                    Select Patient *
                  </label>
                  <select id="client" name="client_id" required>
                    <option value="">Choose a patient...</option>
                    <% clients.forEach(client => { %>
                      <option value="<%= client.id %>" <%= client.id === appointment.client_id ? 'selected' : '' %>>
                        <%= client.name %> - <%= client.email %>
                      </option>
                    <% }) %>
                  </select>
                  <small class="form-help">Select the patient for this appointment</small>
                </div>

                <div class="form-group">
                  <label for="service">
                    <i class="fas fa-tooth"></i>
                    Select Service *
                  </label>
                  <select id="service" name="service_id" required>
                    <option value="">Choose a service...</option>
                    <% services.forEach(service => { %>
                      <option value="<%= service.id %>" <%= service.id === appointment.service ? 'selected' : '' %>>
                        <%= service.name %>
                      </option>
                    <% }) %>
                  </select>
                  <small class="form-help">Select the type of service for this appointment</small>
                </div>
              </div>

              <!-- Scheduling Information -->
              <div class="form-section-group">
                <h3 class="section-group-title">
                  <i class="fas fa-calendar-alt"></i>
                  Scheduling Information
                </h3>

                <div class="form-group">
                  <label for="datetime">
                    <i class="fas fa-clock"></i>
                    Date & Time *
                  </label>
                  <input type="datetime-local" id="datetime" name="appointment_time" value="<%= appointment.appointment_time.toISOString().slice(0,16) %>" required>
                  <small class="form-help">Select the date and time for the appointment</small>
                </div>

                <div class="form-group">
                  <label for="status">
                    <i class="fas fa-check-circle"></i>
                    Status *
                  </label>
                  <select id="status" name="status" required>
                    <option value="Scheduled" <%= appointment.status === 'Scheduled' ? 'selected' : '' %>>Scheduled</option>
                    <option value="Confirmed" <%= appointment.status === 'Confirmed' ? 'selected' : '' %>>Confirmed</option>
                    <option value="Completed" <%= appointment.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                    <option value="Cancelled" <%= appointment.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                  </select>
                  <small class="form-help">Update the status of the appointment</small>
                </div>

                <div class="form-group">
                  <label for="notes">
                    <i class="fas fa-notes-medical"></i>
                    Notes & Instructions
                  </label>
                  <textarea id="notes" name="notes" rows="4" placeholder="Enter any special notes, instructions, or preparation requirements for this appointment..."><%= appointment.notes %></textarea>
                  <small class="form-help">Add any relevant notes or special instructions</small>
                </div>
              </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
              <button type="submit" class="dashboard-btn primary">
                <i class="fas fa-save"></i>
                <span>Update Appointment</span>
              </button>
              <a href="/appointments" class="dashboard-btn secondary">
                <i class="fas fa-list"></i>
                <span>Back to List</span>
              </a>
              <a href="/appointments" class="dashboard-btn">
                <i class="fas fa-times"></i>
                <span>Cancel</span>
              </a>
            </div>
          </form>
        </div>
      </section>
    </main>
  </div>

  <script>
    // Enhanced functionality
    document.addEventListener('DOMContentLoaded', function() {
      // Update current time
      function updateTime() {
        const now = new Date();
        const timeString = now.toLocaleString('en-US', {
          weekday: 'short',
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });
        const timeElement = document.querySelector('#currentTime span');
        if (timeElement) {
          timeElement.textContent = timeString;
        }
      }
      
      updateTime();
      setInterval(updateTime, 60000);

      // Form validation enhancements
      const form = document.querySelector('.enhanced-form');
      const inputs = form.querySelectorAll('input, select, textarea');
      
      inputs.forEach(input => {
        input.addEventListener('focus', function() {
          this.parentElement.classList.add('focused');
        });
        
        input.addEventListener('blur', function() {
          this.parentElement.classList.remove('focused');
          if (this.value) {
            this.parentElement.classList.add('has-value');
          } else {
            this.parentElement.classList.remove('has-value');
          }
        });
        
        // Check if input already has value on page load
        if (input.value) {
          input.parentElement.classList.add('has-value');
        }
      });

      // Add entrance animation
      document.querySelector('.form-container').style.animation = 'slideInUp 0.6s ease-out';

      // Status change animation
      const statusSelect = document.getElementById('status');
      const statusIcon = document.querySelector('.appointment-status-icon i');
      
      statusSelect.addEventListener('change', function() {
        const status = this.value.toLowerCase();
        const iconClasses = {
          'scheduled': 'fa-clock',
          'confirmed': 'fa-check-double', 
          'completed': 'fa-check',
          'cancelled': 'fa-times'
        };
        
        statusIcon.className = `fas ${iconClasses[status] || 'fa-clock'}`;
      });
    });
  </script>
</body>
</html> 