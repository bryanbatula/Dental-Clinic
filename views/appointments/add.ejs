<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Schedule Appointment | Clinic Management</title>
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    /* Searchable Select Styles */
    .searchable-select-container {
      position: relative;
      width: 100%;
    }

    .searchable-select-input {
      width: 100%;
      padding: 12px 40px 12px 16px;
      border: 2px solid #e5e7eb;
      border-radius: 8px;
      font-size: 14px;
      background: white;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .searchable-select-input:focus {
      outline: none;
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .searchable-select-arrow {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: #6b7280;
      pointer-events: none;
      transition: transform 0.2s ease;
    }

    .searchable-select-container.open .searchable-select-arrow {
      transform: translateY(-50%) rotate(180deg);
    }

    .searchable-select-dropdown {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: white;
      border: 2px solid #e5e7eb;
      border-top: none;
      border-radius: 0 0 8px 8px;
      max-height: 200px;
      overflow-y: auto;
      z-index: 1000;
      display: none;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .searchable-select-container.open .searchable-select-dropdown {
      display: block;
    }

    .dropdown-option {
      padding: 12px 16px;
      cursor: pointer;
      transition: background-color 0.2s ease;
      border-bottom: 1px solid #f3f4f6;
    }

    .dropdown-option:last-child {
      border-bottom: none;
    }

    .dropdown-option:hover {
      background-color: #f9fafb;
    }

    .dropdown-option.selected {
      background-color: #eff6ff;
      color: #1d4ed8;
    }

    .dropdown-option.hidden {
      display: none;
    }

    .client-info {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .client-name {
      font-weight: 500;
      color: #111827;
    }

    .client-email {
      font-size: 12px;
      color: #6b7280;
    }

    .dropdown-option.selected .client-name {
      color: #1d4ed8;
    }

    .dropdown-option.selected .client-email {
      color: #3b82f6;
    }
  </style>
</head>
<body>
  <div class="dashboard-wrapper">
    <aside class="dashboard-sidebar">
      <!-- Enhanced User Profile Section -->
      <div class="dashboard-user-profile">
        <div class="user-avatar">
          <i class="fas fa-user-md"></i>
        </div>
        <div class="user-details">
          <h3 class="user-name"><%= user.username %></h3>
          <p class="user-role">Clinic Administrator</p>
          <div class="user-status">
            <span class="status-indicator active"></span>
            <span class="status-text">Online</span>
          </div>
        </div>
      </div>
      
      <!-- Enhanced Navigation -->
      <nav class="dashboard-nav">
        <div class="nav-section">
          <span class="nav-section-title">Main</span>
          <a href="/dashboard" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-pie"></i>
            </div>
            <span class="nav-text">Dashboard</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Management</span>
          <a href="/clients" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-users"></i>
            </div>
            <span class="nav-text">Clients</span>
          </a>
          <a href="/appointments" class="dashboard-nav-item active">
            <div class="nav-icon">
              <i class="far fa-calendar-alt"></i>
            </div>
            <span class="nav-text">Appointments</span>
          </a>
          <a href="/treatments" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-procedures"></i>
            </div>
            <span class="nav-text">Treatments</span>
          </a>
          <a href="/appointments/calendar" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-calendar-week"></i>
            </div>
            <span class="nav-text">Calendar</span>
          </a>
          <a href="/services/manage" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-tooth"></i>
            </div>
            <span class="nav-text">Services</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Tools</span>
          <a href="/reminders" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-bell"></i>
            </div>
            <span class="nav-text">Reminders</span>
          </a>
          <a href="/reports" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-line"></i>
            </div>
            <span class="nav-text">Analytics</span>
          </a>
        </div>
      </nav>
      
      <!-- Enhanced Logout Section -->
      <div class="dashboard-logout">
        <a href="/logout" class="dashboard-logout-btn">
          <i class="fas fa-sign-out-alt"></i>
          <span>Sign Out</span>
        </a>
      </div>
    </aside>

    <main class="dashboard-content">
      <!-- Enhanced Header with Breadcrumb -->
      <header class="dashboard-header">
        <div class="header-content">
          <div class="breadcrumb">
            <span class="breadcrumb-item">Clinic</span>
            <i class="fas fa-chevron-right"></i>
            <span class="breadcrumb-item">
              <a href="/appointments" style="color: #6b7280; text-decoration: none;">Appointments</a>
            </span>
            <i class="fas fa-chevron-right"></i>
            <span class="breadcrumb-item current">Schedule New</span>
          </div>
          <h1 class="dashboard-title">
            <i class="fas fa-calendar-plus title-icon"></i>
            Schedule New Appointment
          </h1>
          <p class="dashboard-subtitle">Create a new appointment for a patient with complete scheduling details</p>
        </div>
        <div class="header-actions">
          <div class="current-time" id="currentTime">
            <i class="far fa-clock"></i>
            <span></span>
          </div>
          <a href="/appointments/calendar" class="dashboard-btn secondary">
            <i class="fas fa-calendar-week"></i>
            <span>Calendar View</span>
          </a>
          <a href="/appointments" class="dashboard-btn">
            <i class="fas fa-arrow-left"></i>
            <span>Back to Appointments</span>
          </a>
        </div>
      </header>

      <!-- Enhanced Form Section -->
      <section class="form-section">
        <div class="form-container">
          <div class="form-header">
            <div class="form-icon">
              <i class="fas fa-calendar-plus"></i>
            </div>
            <div class="form-title-section">
              <h2>Appointment Details</h2>
              <p>Please fill in all required fields to schedule a new appointment</p>
            </div>
          </div>

          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error">
              <i class="fas fa-exclamation-triangle"></i>
              <span><%= error %></span>
            </div>
          <% } %>
          
          <form class="enhanced-form" action="/appointments/add" method="POST">
            <div class="form-grid">
              <!-- Patient & Service Information -->
              <div class="form-section-group">
                <h3 class="section-group-title">
                  <i class="fas fa-user-md"></i>
                  Patient & Service
                </h3>
                
                <div class="form-group">
                  <label for="client">
                    <i class="fas fa-user"></i>
                    Select Patient *
                  </label>
                  <div class="searchable-select-container">
                    <input type="text" id="clientSearch" class="searchable-select-input" 
                           placeholder="Search for a patient..." autocomplete="off">
                    <div class="searchable-select-dropdown" id="clientDropdown">
                      <div class="dropdown-option" data-value="">Select a patient...</div>
                      <% clients.forEach(client => { %>
                        <div class="dropdown-option" data-value="<%= client.id %>" 
                             data-name="<%= client.name %>" data-email="<%= client.email || '' %>"
                             <%= (typeof formData !== 'undefined' && formData.client_id == client.id) ? 'data-selected="true"' : '' %>>
                          <div class="client-info">
                            <div class="client-name"><%= client.name %></div>
                            <div class="client-email"><%= client.email || 'No email' %></div>
                          </div>
                        </div>
                      <% }); %>
                    </div>
                    <input type="hidden" id="client" name="client_id" required>
                    <i class="fas fa-chevron-down searchable-select-arrow"></i>
                  </div>
                  <small class="form-help">Search and select the patient for this appointment</small>
                </div>

                <div class="form-group">
                  <label for="service">
                    <i class="fas fa-tooth"></i>
                    Select Service *
                  </label>
                  <select id="service" name="service_id" required>
                    <option value="">Choose a service...</option>
                    <% services.forEach(service => { %>
                      <option value="<%= service.id %>" <%= (typeof formData !== 'undefined' && formData.service_id == service.id) ? 'selected' : '' %>>
                        <%= service.name %>
                      </option>
                    <% }) %>
                  </select>
                  <small class="form-help">Select the type of service for this appointment</small>
                </div>
              </div>

              <!-- Scheduling Information -->
              <div class="form-section-group">
                <h3 class="section-group-title">
                  <i class="fas fa-calendar-alt"></i>
                  Scheduling Information
                </h3>

                <div class="form-group">
                  <label for="datetime">
                    <i class="fas fa-clock"></i>
                    Date & Time *
                  </label>
                  <input type="datetime-local" id="datetime" name="appointment_time" required 
                         value="<%= typeof formData !== 'undefined' ? formData.appointment_time : '' %>">
                  <small class="form-help">Select the date and time for the appointment</small>
                </div>

                <div class="form-group">
                  <label for="status">
                    <i class="fas fa-check-circle"></i>
                    Status *
                  </label>
                  <select id="status" name="status" required>
                    <option value="Scheduled" <%= (typeof formData !== 'undefined' && formData.status === 'Scheduled') ? 'selected' : 'selected' %>>Scheduled</option>
                    <option value="Confirmed" <%= (typeof formData !== 'undefined' && formData.status === 'Confirmed') ? 'selected' : '' %>>Confirmed</option>
                    <option value="Completed" <%= (typeof formData !== 'undefined' && formData.status === 'Completed') ? 'selected' : '' %>>Completed</option>
                    <option value="Cancelled" <%= (typeof formData !== 'undefined' && formData.status === 'Cancelled') ? 'selected' : '' %>>Cancelled</option>
                  </select>
                  <small class="form-help">Set the initial status of the appointment</small>
                </div>

                <div class="form-group">
                  <label for="notes">
                    <i class="fas fa-notes-medical"></i>
                    Notes & Instructions
                  </label>
                  <textarea id="notes" name="notes" rows="4" placeholder="Enter any special notes, instructions, or preparation requirements for this appointment..."><%= typeof formData !== 'undefined' ? formData.notes : '' %></textarea>
                  <small class="form-help">Add any relevant notes or special instructions</small>
                </div>
              </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
              <button type="submit" class="dashboard-btn primary">
                <i class="fas fa-calendar-plus"></i>
                <span>Schedule Appointment</span>
              </button>
              <a href="/appointments" class="dashboard-btn secondary">
                <i class="fas fa-times"></i>
                <span>Cancel</span>
              </a>
            </div>
          </form>
        </div>
      </section>
    </main>
  </div>

  <script>
    // Enhanced functionality
    document.addEventListener('DOMContentLoaded', function() {
      // Update current time
      function updateTime() {
        const now = new Date();
        const timeString = now.toLocaleString('en-US', {
          weekday: 'short',
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });
        const timeElement = document.querySelector('#currentTime span');
        if (timeElement) {
          timeElement.textContent = timeString;
        }
      }
      
      updateTime();
      setInterval(updateTime, 60000);

      // Form validation enhancements
      const form = document.querySelector('.enhanced-form');
      const inputs = form.querySelectorAll('input, select, textarea');
      
      inputs.forEach(input => {
        input.addEventListener('focus', function() {
          this.parentElement.classList.add('focused');
        });
        
        input.addEventListener('blur', function() {
          this.parentElement.classList.remove('focused');
          if (this.value) {
            this.parentElement.classList.add('has-value');
          } else {
            this.parentElement.classList.remove('has-value');
          }
        });
        
        // Check if input already has value on page load
        if (input.value) {
          input.parentElement.classList.add('has-value');
        }
      });

      // Pre-fill date if coming from calendar
      const urlParams = new URLSearchParams(window.location.search);
      const dateParam = urlParams.get('date');
      const clientParam = urlParams.get('client_id');
      const datetimeInput = document.getElementById('datetime');
      
      if (dateParam && !datetimeInput.value) {
        // Set the date part, default time to 9:00 AM
        const selectedDate = new Date(dateParam + 'T09:00');
        const isoString = selectedDate.toISOString().slice(0, 16);
        datetimeInput.value = isoString;
        datetimeInput.parentElement.classList.add('has-value');
      }

      // Pre-select client if coming from client page
      if (clientParam) {
        const clientOption = document.querySelector(`[data-value="${clientParam}"]`);
        if (clientOption) {
          const clientName = clientOption.dataset.name;
          const clientEmail = clientOption.dataset.email;
          const input = document.getElementById('clientSearch');
          const hiddenInput = document.getElementById('client');
          
          input.value = `${clientName} - ${clientEmail}`;
          hiddenInput.value = clientParam;
          clientOption.classList.add('selected');
          input.parentElement.classList.add('has-value');
        }
      }

      // Initialize searchable select functionality
      initializeSearchableSelect();

      // Add entrance animation
      document.querySelector('.form-container').style.animation = 'slideInUp 0.6s ease-out';
    });

    // Searchable Select Functionality
    function initializeSearchableSelect() {
      const container = document.querySelector('.searchable-select-container');
      const input = document.getElementById('clientSearch');
      const dropdown = document.getElementById('clientDropdown');
      const hiddenInput = document.getElementById('client');
      const options = dropdown.querySelectorAll('.dropdown-option');
      
      let isOpen = false;
      
      // Check for pre-selected value
      const preSelected = dropdown.querySelector('[data-selected="true"]');
      if (preSelected) {
        const clientName = preSelected.dataset.name;
        const clientEmail = preSelected.dataset.email;
        input.value = `${clientName} - ${clientEmail}`;
        hiddenInput.value = preSelected.dataset.value;
        preSelected.classList.add('selected');
      }
      
      // Toggle dropdown
      function toggleDropdown() {
        isOpen = !isOpen;
        container.classList.toggle('open', isOpen);
        if (isOpen) {
          input.focus();
          filterOptions('');
        }
      }
      
      // Close dropdown
      function closeDropdown() {
        isOpen = false;
        container.classList.remove('open');
      }
      
      // Filter options based on search
      function filterOptions(searchTerm) {
        const term = searchTerm.toLowerCase();
        options.forEach(option => {
          if (option.dataset.value === '') {
            option.classList.remove('hidden');
            return;
          }
          
          const name = option.dataset.name.toLowerCase();
          const email = option.dataset.email.toLowerCase();
          
          if (name.includes(term) || email.includes(term)) {
            option.classList.remove('hidden');
          } else {
            option.classList.add('hidden');
          }
        });
      }
      
      // Select option
      function selectOption(option) {
        // Clear previous selection
        options.forEach(opt => opt.classList.remove('selected'));
        
        if (option.dataset.value === '') {
          input.value = '';
          hiddenInput.value = '';
        } else {
          const clientName = option.dataset.name;
          const clientEmail = option.dataset.email;
          input.value = `${clientName} - ${clientEmail}`;
          hiddenInput.value = option.dataset.value;
          option.classList.add('selected');
        }
        
        closeDropdown();
      }
      
      // Event listeners
      input.addEventListener('click', toggleDropdown);
      input.addEventListener('input', (e) => {
        if (!isOpen) toggleDropdown();
        filterOptions(e.target.value);
      });
      
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          closeDropdown();
        } else if (e.key === 'ArrowDown' && isOpen) {
          e.preventDefault();
          const visibleOptions = Array.from(options).filter(opt => !opt.classList.contains('hidden'));
          if (visibleOptions.length > 0) {
            visibleOptions[0].focus();
          }
        }
      });
      
      // Option click handlers
      options.forEach(option => {
        option.addEventListener('click', () => selectOption(option));
        
        option.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            selectOption(option);
          }
        });
      });
      
      // Close dropdown when clicking outside
      document.addEventListener('click', (e) => {
        if (!container.contains(e.target)) {
          closeDropdown();
        }
      });
    }
  </script>
</body>
</html> 