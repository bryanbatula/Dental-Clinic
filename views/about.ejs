<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/assets/style.css">
</head>
<body>
  <%- include('partials/navbar') %>
  <main class="about-main">
    <section class="about-story">
      <h1>About SmileBright Dental Clinic</h1>
      <p>Founded in 2010, SmileBright Dental Clinic is dedicated to providing exceptional dental care in a welcoming and modern environment. Our mission is to help every patient achieve a healthy, beautiful smile with comfort and confidence.</p>
      <p>We combine advanced technology, gentle techniques, and a patient-first approach to make every visit a positive experience.</p>
    </section>
    <section class="about-team">
      <h2>Meet Our Team</h2>
      <div class="team-list">
        <div class="team-member">
          <img src="/assets/images/doctor1.jpg" alt="Dr. Jane Smith">
          <h3>Dr. Jane Smith</h3>
          <p>Lead Dentist</p>
        </div>
        <div class="team-member">
          <img src="/assets/images/doctor2.jpg" alt="Dr. John Lee">
          <h3>Dr. John Lee</h3>
          <p>Orthodontist</p>
        </div>
        <div class="team-member">
          <img src="/assets/images/doctor3.jpg" alt="Dr. Emily Chen">
          <h3>Dr. Emily Chen</h3>
          <p>Pediatric Dentist</p>
        </div>
      </div>
    </section>
    <section class="about-cta">
      <h2>Ready for a Brighter Smile?</h2>
      <a href="/contact" class="cta-btn">Book Your Visit</a>
    </section>
  </main>
  <footer>
    <%- include('partials/footer') %>
  </footer>
</body>
</html> 