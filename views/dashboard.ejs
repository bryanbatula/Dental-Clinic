<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard | Clinic Management</title>
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
  <div class="dashboard-wrapper">
    <aside class="dashboard-sidebar">
      <!-- Enhanced User Profile Section -->
      <div class="dashboard-user-profile">
        <div class="user-avatar">
          <i class="fas fa-user-md"></i>
        </div>
        <div class="user-details">
          <h3 class="user-name"><%= user.username %></h3>
          <p class="user-role">Clinic Administrator</p>
          <div class="user-status">
            <span class="status-indicator active"></span>
            <span class="status-text">Online</span>
          </div>
        </div>
      </div>
      
      <!-- Enhanced Navigation -->
      <nav class="dashboard-nav">
        <div class="nav-section">
          <span class="nav-section-title">Main</span>
          <a href="/dashboard" class="dashboard-nav-item active">
            <div class="nav-icon">
              <i class="fas fa-chart-pie"></i>
            </div>
            <span class="nav-text">Dashboard</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Management</span>
          <a href="/clients" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-users"></i>
            </div>
            <span class="nav-text">Clients</span>
          </a>
          <a href="/appointments" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="far fa-calendar-alt"></i>
            </div>
            <span class="nav-text">Appointments</span>
          </a>
          <a href="/treatments" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-procedures"></i>
            </div>
            <span class="nav-text">Treatments</span>
          </a>
          <a href="/appointments/calendar" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-calendar-week"></i>
            </div>
            <span class="nav-text">Calendar</span>
          </a>
          <a href="/services/manage" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-tooth"></i>
            </div>
            <span class="nav-text">Services</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Tools</span>
          <a href="/reminders" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-bell"></i>
            </div>
            <span class="nav-text">Reminders</span>
          </a>
          <a href="/reports" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-line"></i>
            </div>
            <span class="nav-text">Analytics</span>
          </a>
        </div>
      </nav>
      
      <!-- Enhanced Logout Section -->
      <div class="dashboard-logout">
        <a href="/logout" class="dashboard-logout-btn">
          <i class="fas fa-sign-out-alt"></i>
          <span>Sign Out</span>
        </a>
      </div>
    </aside>

    <main class="dashboard-content">
      <!-- Enhanced Header with Breadcrumb and Time -->
      <header class="dashboard-header">
        <div class="header-content">
          <div class="breadcrumb">
            <span class="breadcrumb-item">Clinic</span>
            <i class="fas fa-chevron-right"></i>
            <span class="breadcrumb-item current">Dashboard</span>
          </div>
          <h1 class="dashboard-title">
            <i class="fas fa-chart-pie title-icon"></i>
            Dashboard Overview
          </h1>
          <p class="dashboard-subtitle">Welcome back! Here's what's happening at your clinic today.</p>
        </div>
        <div class="header-actions">
          <div class="current-time" id="currentTime">
            <i class="far fa-clock"></i>
            <span></span>
          </div>
          <button id="refreshStatsBtn" class="dashboard-btn primary" onclick="refreshDashboardStats()">
            <i class="fas fa-sync-alt"></i>
            <span>Refresh</span>
          </button>
        </div>
      </header>

      <!-- Enhanced Statistics Section -->
      <section class="dashboard-stats-section">
        <div class="section-header">
          <h2 class="section-title">
            <i class="fas fa-chart-bar"></i>
            Quick Statistics
          </h2>
          <p class="section-subtitle">Real-time overview of your clinic's performance</p>
        </div>
        
        <div class="stats-grid">
          <div class="stat-card clients">
            <div class="stat-icon">
              <i class="fas fa-users"></i>
            </div>
            <div class="stat-content">
              <div class="stat-value" data-target="<%= stats.totalClients %>">0</div>
              <div class="stat-label">Total Clients</div>
              <div class="stat-trend">
                <i class="fas fa-users"></i>
                <span>Registered patients</span>
              </div>
            </div>
          </div>
          
          <div class="stat-card appointments">
            <div class="stat-icon">
              <i class="fas fa-calendar-check"></i>
            </div>
            <div class="stat-content">
              <div class="stat-value" data-target="<%= stats.totalAppointments %>">0</div>
              <div class="stat-label">Total Appointments</div>
              <div class="stat-trend">
                <i class="fas fa-calendar"></i>
                <span>All time bookings</span>
              </div>
            </div>
          </div>
          
          <div class="stat-card today">
            <div class="stat-icon">
              <i class="fas fa-calendar-day"></i>
            </div>
            <div class="stat-content">
              <div class="stat-value" data-target="<%= stats.todayAppointments %>">0</div>
              <div class="stat-label">Today's Appointments</div>
              <div class="stat-trend">
                <i class="fas fa-clock"></i>
                <span><%= stats.todayAppointments > 0 ? 'Scheduled for today' : 'No appointments today' %></span>
              </div>
            </div>
          </div>
          
          <div class="stat-card satisfaction">
            <div class="stat-icon">
              <i class="fas fa-heart"></i>
            </div>
            <div class="stat-content">
              <div class="stat-value" data-target="<%= stats.clientSatisfaction %>"><%= stats.clientSatisfaction %>%</div>
              <div class="stat-label">Completion Rate</div>
              <div class="stat-trend">
                <i class="fas fa-<%= stats.clientSatisfaction >= 80 ? 'arrow-up' : stats.clientSatisfaction >= 60 ? 'minus' : 'arrow-down' %>"></i>
                <span><%= stats.clientSatisfaction >= 80 ? 'Excellent' : stats.clientSatisfaction >= 60 ? 'Good' : 'Needs improvement' %></span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Enhanced Quick Actions Section -->
      <section class="dashboard-actions-section">
        <div class="section-header">
          <h2 class="section-title">
            <i class="fas fa-bolt"></i>
            Quick Actions
          </h2>
          <p class="section-subtitle">Access frequently used features and tools</p>
        </div>
        
        <div class="actions-grid">
          <a href="/clients" class="action-card primary">
            <div class="action-header">
              <div class="action-icon">
                <i class="fas fa-user-plus"></i>
              </div>
              <div class="action-badge">
                <span>Popular</span>
              </div>
            </div>
            <div class="action-content">
              <h3 class="action-title">Manage Clients</h3>
              <p class="action-description">Add new patients, update records, and view medical history with ease.</p>
            </div>
            <div class="action-footer">
              <span class="action-link">Get started <i class="fas fa-arrow-right"></i></span>
            </div>
          </a>
          
          <a href="/appointments" class="action-card secondary">
            <div class="action-header">
              <div class="action-icon">
                <i class="fas fa-calendar-plus"></i>
              </div>
            </div>
            <div class="action-content">
              <h3 class="action-title">Schedule Appointments</h3>
              <p class="action-description">Book new appointments and manage existing schedules efficiently.</p>
            </div>
            <div class="action-footer">
              <span class="action-link">Schedule now <i class="fas fa-arrow-right"></i></span>
            </div>
          </a>
          
          <a href="/appointments/calendar" class="action-card accent">
            <div class="action-header">
              <div class="action-icon">
                <i class="fas fa-calendar-week"></i>
              </div>
            </div>
            <div class="action-content">
              <h3 class="action-title">Calendar View</h3>
              <p class="action-description">Visualize appointments in an interactive calendar interface.</p>
            </div>
            <div class="action-footer">
              <span class="action-link">View calendar <i class="fas fa-arrow-right"></i></span>
            </div>
          </a>
          
          <a href="/treatments" class="action-card info">
            <div class="action-header">
              <div class="action-icon">
                <i class="fas fa-procedures"></i>
              </div>
            </div>
            <div class="action-content">
              <h3 class="action-title">Treatment Records</h3>
              <p class="action-description">Manage patient treatments, procedures, and medical history.</p>
            </div>
            <div class="action-footer">
              <span class="action-link">View treatments <i class="fas fa-arrow-right"></i></span>
            </div>
          </a>
          
          <a href="/services/manage" class="action-card warning">
            <div class="action-header">
              <div class="action-icon">
                <i class="fas fa-tooth"></i>
              </div>
            </div>
            <div class="action-content">
              <h3 class="action-title">Dental Services</h3>
              <p class="action-description">Manage service offerings, pricing, and treatment categories.</p>
            </div>
            <div class="action-footer">
              <span class="action-link">Manage services <i class="fas fa-arrow-right"></i></span>
            </div>
          </a>
          
          <a href="/reminders" class="action-card accent">
            <div class="action-header">
              <div class="action-icon">
                <i class="fas fa-bell"></i>
              </div>
              <% if (stats.pendingReminders > 0) { %>
              <div class="action-notification">
                <span><%= stats.pendingReminders %></span>
              </div>
              <% } %>
            </div>
            <div class="action-content">
              <h3 class="action-title">Patient Reminders</h3>
              <p class="action-description">Send appointment reminders and follow-up notifications.</p>
            </div>
            <div class="action-footer">
              <span class="action-link">View reminders <i class="fas fa-arrow-right"></i></span>
            </div>
          </a>
          
          <a href="/reports" class="action-card success">
            <div class="action-header">
              <div class="action-icon">
                <i class="fas fa-chart-line"></i>
              </div>
            </div>
            <div class="action-content">
              <h3 class="action-title">Analytics & Reports</h3>
              <p class="action-description">Generate insights and detailed performance reports.</p>
            </div>
            <div class="action-footer">
              <span class="action-link">View analytics <i class="fas fa-arrow-right"></i></span>
            </div>
          </a>
        </div>
      </section>
    </main>
  </div>

  <script>
    // Enhanced dashboard functionality
    document.addEventListener('DOMContentLoaded', function() {
      // Update current time
      function updateTime() {
        const now = new Date();
        const timeString = now.toLocaleString('en-US', {
          weekday: 'short',
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });
        const timeElement = document.querySelector('#currentTime span');
        if (timeElement) {
          timeElement.textContent = timeString;
        }
      }
      
      // Update time immediately and every minute
      updateTime();
      setInterval(updateTime, 60000);
      
      // Animate stat values
      function animateStatValues() {
        const statValues = document.querySelectorAll('.stat-value[data-target]');
        statValues.forEach(stat => {
          const target = parseInt(stat.getAttribute('data-target')) || 0;
          const duration = 2000; // 2 seconds
          const startTime = Date.now();
          const startValue = parseInt(stat.textContent) || 0;
          
          function updateValue() {
            const elapsed = Date.now() - startTime;
            const progress = Math.min(elapsed / duration, 1);
            
            // Easing function for smooth animation
            const easeOutQuart = 1 - Math.pow(1 - progress, 4);
            const currentValue = Math.round(startValue + (target - startValue) * easeOutQuart);
            
            if (stat.textContent.includes('%')) {
              stat.textContent = currentValue + '%';
            } else {
              stat.textContent = currentValue.toLocaleString();
            }
            
            if (progress < 1) {
              requestAnimationFrame(updateValue);
            }
          }
          
          if (target !== startValue) {
            requestAnimationFrame(updateValue);
          }
        });
      }
      
      // Start animation after a short delay
      setTimeout(animateStatValues, 500);
      
      // Add entrance animations
      const cards = document.querySelectorAll('.stat-card, .action-card');
      cards.forEach((card, index) => {
        card.style.animation = `slideInUp 0.6s ease-out ${index * 0.1}s both`;
      });
      
      // Add hover effects
      const actionCards = document.querySelectorAll('.action-card');
      actionCards.forEach(card => {
        card.addEventListener('mouseenter', function() {
          this.style.transform = 'translateY(-8px) scale(1.02)';
        });
        
        card.addEventListener('mouseleave', function() {
          this.style.transform = 'translateY(0) scale(1)';
        });
      });
    });
    
    // Global function for refreshing dashboard statistics
    async function refreshDashboardStats() {
      const refreshBtn = document.getElementById('refreshStatsBtn');
      const refreshIcon = refreshBtn.querySelector('i');
      
      // Show loading state
      refreshBtn.disabled = true;
      refreshIcon.classList.add('fa-spin');
      
      try {
        const response = await fetch('/api/dashboard-stats');
        const stats = await response.json();
        
        if (response.ok) {
          // Update stat values with new data
          updateStatCard('clients', stats.totalClients, 'Registered patients');
          updateStatCard('appointments', stats.totalAppointments, 'All time bookings');
          updateStatCard('today', stats.todayAppointments, 
            stats.todayAppointments > 0 ? 'Scheduled for today' : 'No appointments today');
          updateStatCard('satisfaction', stats.clientSatisfaction, 
            stats.clientSatisfaction >= 80 ? 'Excellent' : 
            stats.clientSatisfaction >= 60 ? 'Good' : 'Needs improvement', true);
          
          // Update reminders notification
          updateRemindersNotification(stats.pendingReminders);
          
          // Show success feedback
          showNotification('Dashboard updated successfully!', 'success');
        } else {
          throw new Error('Failed to fetch stats');
        }
      } catch (error) {
        console.error('Error refreshing stats:', error);
        showNotification('Failed to refresh dashboard. Please try again.', 'error');
      } finally {
        // Reset button state
        refreshBtn.disabled = false;
        refreshIcon.classList.remove('fa-spin');
      }
    }
    
    // Helper function to update individual stat cards
    function updateStatCard(cardClass, newValue, trendText, isPercentage = false) {
      const card = document.querySelector(`.stat-card.${cardClass}`);
      if (card) {
        const valueElement = card.querySelector('.stat-value');
        const trendElement = card.querySelector('.stat-trend span');
        
        if (valueElement) {
          valueElement.setAttribute('data-target', newValue);
          // Animate to new value
          animateSingleStat(valueElement, newValue, isPercentage);
        }
        
        if (trendElement) {
          trendElement.textContent = trendText;
        }
        
        // Update trend icon for satisfaction
        if (cardClass === 'satisfaction') {
          const trendIcon = card.querySelector('.stat-trend i');
          if (trendIcon) {
            trendIcon.className = `fas fa-${newValue >= 80 ? 'arrow-up' : newValue >= 60 ? 'minus' : 'arrow-down'}`;
          }
        }
      }
    }
    
    // Helper function to animate a single stat
    function animateSingleStat(element, target, isPercentage = false) {
      const startValue = parseInt(element.textContent) || 0;
      const duration = 1500;
      const startTime = Date.now();
      
      function updateValue() {
        const elapsed = Date.now() - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const easeOutQuart = 1 - Math.pow(1 - progress, 4);
        const currentValue = Math.round(startValue + (target - startValue) * easeOutQuart);
        
        element.textContent = isPercentage ? currentValue + '%' : currentValue.toLocaleString();
        
        if (progress < 1) {
          requestAnimationFrame(updateValue);
        }
      }
      
      requestAnimationFrame(updateValue);
    }
    
    // Helper function to update reminders notification
    function updateRemindersNotification(count) {
      const reminderCard = document.querySelector('.action-card[href="/reminders"]');
      if (reminderCard) {
        let notification = reminderCard.querySelector('.action-notification');
        
        if (count > 0) {
          if (!notification) {
            notification = document.createElement('div');
            notification.className = 'action-notification';
            notification.innerHTML = `<span>${count}</span>`;
            reminderCard.querySelector('.action-header').appendChild(notification);
          } else {
            notification.querySelector('span').textContent = count;
            notification.style.display = '';
          }
        } else if (notification) {
          notification.style.display = 'none';
        }
      }
    }
    
    // Simple notification system
    function showNotification(message, type = 'info') {
      // Remove existing notifications
      const existing = document.querySelector('.dashboard-notification');
      if (existing) existing.remove();
      
      const notification = document.createElement('div');
      notification.className = `dashboard-notification ${type}`;
      notification.innerHTML = `
        <i class="fas fa-${type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle'}"></i>
        <span>${message}</span>
      `;
      
      document.body.appendChild(notification);
      
      // Auto remove after 3 seconds
      setTimeout(() => {
        if (notification.parentNode) {
          notification.remove();
        }
      }, 3000);
    }
    
    // Add slide-in animation keyframes
    const style = document.createElement('style');
    style.textContent = `
      @keyframes slideInUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      
      @keyframes pulse {
        0% {
          transform: scale(1);
        }
        50% {
          transform: scale(1.1);
        }
        100% {
          transform: scale(1);
        }
      }
      
      .pulse-animation {
        animation: pulse 0.6s ease-in-out 3;
      }
      
      .action-notification {
        transition: opacity 0.3s ease, transform 0.3s ease;
      }
      
      .dashboard-notification {
        position: fixed;
        top: 20px;
        right: 20px;
        background: #ffffff;
        border-radius: 8px;
        padding: 16px 20px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
        display: flex;
        align-items: center;
        gap: 12px;
        z-index: 1000;
        font-weight: 500;
        animation: slideInRight 0.3s ease-out;
      }
      
      .dashboard-notification.success {
        border-left: 4px solid #10b981;
        color: #065f46;
      }
      
      .dashboard-notification.error {
        border-left: 4px solid #ef4444;
        color: #7f1d1d;
      }
      
      .dashboard-notification.info {
        border-left: 4px solid #3b82f6;
        color: #1e3a8a;
      }
      
      .dashboard-notification i {
        font-size: 18px;
      }
      
      .dashboard-notification.success i {
        color: #10b981;
      }
      
      .dashboard-notification.error i {
        color: #ef4444;
      }
      
      .dashboard-notification.info i {
        color: #3b82f6;
      }
      
      @keyframes slideInRight {
        from {
          opacity: 0;
          transform: translateX(100%);
        }
        to {
          opacity: 1;
          transform: translateX(0);
        }
      }
    `;
    document.head.appendChild(style);
  </script>
</body>
</html> 