<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Client | Clinic Management</title>
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
  <div class="dashboard-wrapper">
    <aside class="dashboard-sidebar">
      <!-- Enhanced User Profile Section -->
      <div class="dashboard-user-profile">
        <div class="user-avatar">
          <i class="fas fa-user-md"></i>
        </div>
        <div class="user-details">
          <h3 class="user-name"><%= user.username %></h3>
          <p class="user-role">Clinic Administrator</p>
          <div class="user-status">
            <span class="status-indicator active"></span>
            <span class="status-text">Online</span>
          </div>
        </div>
      </div>
      
      <!-- Enhanced Navigation -->
      <nav class="dashboard-nav">
        <div class="nav-section">
          <span class="nav-section-title">Main</span>
          <a href="/dashboard" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-pie"></i>
            </div>
            <span class="nav-text">Dashboard</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Management</span>
          <a href="/clients" class="dashboard-nav-item active">
            <div class="nav-icon">
              <i class="fas fa-users"></i>
            </div>
            <span class="nav-text">Clients</span>
          </a>
          <a href="/appointments" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="far fa-calendar-alt"></i>
            </div>
            <span class="nav-text">Appointments</span>
          </a>
          <a href="/treatments" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-procedures"></i>
            </div>
            <span class="nav-text">Treatments</span>
          </a>
          <a href="/appointments/calendar" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-calendar-week"></i>
            </div>
            <span class="nav-text">Calendar</span>
          </a>
          <a href="/services/manage" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-tooth"></i>
            </div>
            <span class="nav-text">Services</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Tools</span>
          <a href="/reminders" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-bell"></i>
            </div>
            <span class="nav-text">Reminders</span>
          </a>
          <a href="/reports" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-line"></i>
            </div>
            <span class="nav-text">Analytics</span>
          </a>
        </div>
      </nav>
      
      <!-- Enhanced Logout Section -->
      <div class="dashboard-logout">
        <a href="/logout" class="dashboard-logout-btn">
          <i class="fas fa-sign-out-alt"></i>
          <span>Sign Out</span>
        </a>
      </div>
    </aside>

    <main class="dashboard-content">
      <!-- Enhanced Header with Breadcrumb -->
      <header class="dashboard-header">
        <div class="header-content">
          <div class="breadcrumb">
            <span class="breadcrumb-item">Clinic</span>
            <i class="fas fa-chevron-right"></i>
            <span class="breadcrumb-item">
              <a href="/clients" style="color: #6b7280; text-decoration: none;">Clients</a>
            </span>
            <i class="fas fa-chevron-right"></i>
            <span class="breadcrumb-item current">Edit Client</span>
          </div>
          <h1 class="dashboard-title">
            <i class="fas fa-user-edit title-icon"></i>
            Edit Client Information
          </h1>
          <p class="dashboard-subtitle">Update patient records and medical information for <%= client.name %></p>
        </div>
        <div class="header-actions">
          <div class="current-time" id="currentTime">
            <i class="far fa-clock"></i>
            <span></span>
          </div>
          <a href="/clients/view/<%= client.id %>" class="dashboard-btn">
            <i class="fas fa-eye"></i>
            <span>View Client</span>
          </a>
          <a href="/clients" class="dashboard-btn">
            <i class="fas fa-arrow-left"></i>
            <span>Back to Clients</span>
          </a>
        </div>
      </header>

      <!-- Enhanced Form Section -->
      <section class="form-section">
        <div class="form-container">
          <div class="form-header">
            <div class="client-avatar-large">
              <%= client.name.charAt(0).toUpperCase() %>
            </div>
            <div class="form-title-section">
              <h2>Editing: <%= client.name %></h2>
              <p>Patient ID: #<%= client.id %> • Update information as needed</p>
            </div>
          </div>

          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error">
              <i class="fas fa-exclamation-triangle"></i>
              <span><%= error %></span>
            </div>
          <% } %>
          
          <form class="enhanced-form" action="/clients/edit/<%= client.id %>" method="POST">
            <div class="form-grid">
              <!-- Personal Information Section -->
              <div class="form-section-group">
                <h3 class="section-group-title">
                  <i class="fas fa-user"></i>
                  Personal Information
                </h3>
                
                <div class="form-group">
                  <label for="name">
                    <i class="fas fa-user"></i>
                    Full Name *
                  </label>
                  <input type="text" id="name" name="name" value="<%= client.name %>" required placeholder="Enter patient's full name">
                </div>

                <div class="form-row">
                  <div class="form-group">
                    <label for="email">
                      <i class="fas fa-envelope"></i>
                      Email Address
                    </label>
                    <input type="email" id="email" name="email" value="<%= client.email || '' %>" placeholder="patient@email.com">
                  </div>

                  <div class="form-group">
                    <label for="phone">
                      <i class="fas fa-phone"></i>
                      Phone Number
                    </label>
                    <input type="tel" id="phone" name="phone" value="<%= client.phone || '' %>" placeholder="+1 (555) 123-4567">
                  </div>
                </div>

                <div class="form-group">
                  <label for="dob">
                    <i class="fas fa-birthday-cake"></i>
                    Date of Birth
                  </label>
                  <input type="date" id="dob" name="dob" value="<%= client.dob ? client.dob.toISOString().split('T')[0] : '' %>">
                  <% if (client.dob) { %>
                    <small class="form-help">Current age: <%= Math.floor((new Date() - new Date(client.dob)) / (365.25 * 24 * 60 * 60 * 1000)) %> years</small>
                  <% } %>
                </div>

                <div class="form-group">
                  <label for="address">
                    <i class="fas fa-map-marker-alt"></i>
                    Address
                  </label>
                  <textarea id="address" name="address" rows="2" placeholder="Enter patient's full address"><%= client.address || '' %></textarea>
                </div>
              </div>

              <!-- Medical Information Section -->
              <div class="form-section-group">
                <h3 class="section-group-title">
                  <i class="fas fa-heartbeat"></i>
                  Medical Information
                </h3>

                <div class="form-group">
                  <label for="medicalHistory">
                    <i class="fas fa-notes-medical"></i>
                    Medical History
                  </label>
                  <textarea id="medicalHistory" name="medicalHistory" rows="4" placeholder="Enter any relevant medical history, allergies, medications, previous treatments, etc."><%= client.medical_history || '' %></textarea>
                  <small class="form-help">Include allergies, current medications, chronic conditions, previous surgeries, etc.</small>
                </div>

                <div class="form-group">
                  <label for="notes">
                    <i class="fas fa-sticky-note"></i>
                    Additional Notes
                  </label>
                  <textarea id="notes" name="notes" rows="3" placeholder="Any additional notes about the patient (preferences, special instructions, etc.)"><%= client.notes || '' %></textarea>
                </div>
              </div>

              <!-- Dental Chart Section -->
              <div class="form-section-group">
                <h3 class="section-group-title">
                  <i class="fas fa-tooth"></i>
                  Dental Chart
                </h3>
                
                <!-- Treatment Legend -->
                <div class="treatment-legend">
                  <div class="legend-item" data-treatment="C">
                    <span class="legend-symbol c">C</span>
                    <span>Indicated for Filling</span>
                  </div>
                  <div class="legend-item" data-treatment="II">
                    <span class="legend-symbol ii">II</span>
                    <span>Indicated for Extraction</span>
                  </div>
                  <div class="legend-item" data-treatment="X">
                    <span class="legend-symbol x">X</span>
                    <span>Missing Tooth</span>
                  </div>
                  <div class="legend-item" data-treatment="LC">
                    <span class="legend-symbol lc">LC</span>
                    <span>Composite Filling</span>
                  </div>
                  <div class="legend-item" data-treatment="AM">
                    <span class="legend-symbol am">AM</span>
                    <span>Amalgam Filling</span>
                  </div>
                  <div class="legend-item" data-treatment="Se">
                    <span class="legend-symbol se">Se</span>
                    <span>Sealants</span>
                  </div>
                  <div class="legend-item" data-treatment="IMO">
                    <span class="legend-symbol imo">IMO</span>
                    <span>Impacted Tooth</span>
                  </div>
                  <div class="legend-item" data-treatment="FB">
                    <span class="legend-symbol fb">FB</span>
                    <span>Fixed Bridge Crown</span>
                  </div>
                  <div class="legend-item" data-treatment="JC">
                    <span class="legend-symbol jc">JC</span>
                    <span>Jacket Crown</span>
                  </div>
                  <div class="legend-item" data-treatment="PM">
                    <span class="legend-symbol pm">PM</span>
                    <span>Removable Denture</span>
                  </div>
                </div>

                <!-- Dental Chart -->
                <div class="dental-chart">
                  <!-- Upper Baby Teeth -->
                  <div class="teeth-row upper-baby">
                    <div class="teeth-numbers">
                      <span>55</span><span>54</span><span>53</span><span>52</span><span>51</span>
                      <span>61</span><span>62</span><span>63</span><span>64</span><span>65</span>
                    </div>
                    <div class="teeth-visual">
                      <div class="tooth" data-number="55"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="54"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="53"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="52"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="51"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="61"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="62"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="63"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="64"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="65"><div class="tooth-circle"></div></div>
                    </div>
                  </div>

                  <!-- Adult Upper Teeth -->
                  <div class="teeth-row adult-upper">
                    <div class="teeth-numbers">
                      <span>18</span><span>17</span><span>16</span><span>15</span><span>14</span><span>13</span><span>12</span><span>11</span>
                      <span>21</span><span>22</span><span>23</span><span>24</span><span>25</span><span>26</span><span>27</span><span>28</span>
                    </div>
                    <div class="teeth-visual">
                      <div class="tooth" data-number="18"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="17"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="16"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="15"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="14"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="13"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="12"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="11"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="21"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="22"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="23"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="24"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="25"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="26"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="27"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="28"><div class="tooth-circle"></div></div>
                    </div>
                  </div>

                  <!-- Adult Lower Teeth -->
                  <div class="teeth-row adult-lower">
                    <div class="teeth-visual">
                      <div class="tooth" data-number="48"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="47"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="46"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="45"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="44"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="43"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="42"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="41"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="31"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="32"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="33"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="34"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="35"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="36"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="37"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="38"><div class="tooth-circle"></div></div>
                    </div>
                    <div class="teeth-numbers">
                      <span>48</span><span>47</span><span>46</span><span>45</span><span>44</span><span>43</span><span>42</span><span>41</span>
                      <span>31</span><span>32</span><span>33</span><span>34</span><span>35</span><span>36</span><span>37</span><span>38</span>
                    </div>
                  </div>

                  <!-- Lower Baby Teeth -->
                  <div class="teeth-row lower-baby">
                    <div class="teeth-visual">
                      <div class="tooth" data-number="85"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="84"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="83"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="82"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="81"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="71"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="72"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="73"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="74"><div class="tooth-circle"></div></div>
                      <div class="tooth" data-number="75"><div class="tooth-circle"></div></div>
                    </div>
                    <div class="teeth-numbers">
                      <span>85</span><span>84</span><span>83</span><span>82</span><span>81</span>
                      <span>71</span><span>72</span><span>73</span><span>74</span><span>75</span>
                    </div>
                  </div>
                </div>

                <!-- Hidden field to store dental chart data -->
                <input type="hidden" id="dentalChartData" name="dentalChart" value="<%= client.dental_chart || '{}' %>">
              </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
              <button type="submit" class="dashboard-btn primary">
                <i class="fas fa-save"></i>
                <span>Update Client</span>
              </button>
              <a href="/clients/view/<%= client.id %>" class="dashboard-btn secondary">
                <i class="fas fa-eye"></i>
                <span>View Client</span>
              </a>
              <a href="/clients" class="dashboard-btn">
                <i class="fas fa-times"></i>
                <span>Cancel</span>
              </a>
            </div>
          </form>
        </div>
      </section>
    </main>
  </div>

  <script>
    // Enhanced functionality
    document.addEventListener('DOMContentLoaded', function() {
      // Update current time
      function updateTime() {
        const now = new Date();
        const timeString = now.toLocaleString('en-US', {
          weekday: 'short',
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });
        const timeElement = document.querySelector('#currentTime span');
        if (timeElement) {
          timeElement.textContent = timeString;
        }
      }
      
      updateTime();
      setInterval(updateTime, 60000);

      // Form validation enhancements
      const form = document.querySelector('.enhanced-form');
      const inputs = form.querySelectorAll('input, textarea');
      
      inputs.forEach(input => {
        input.addEventListener('focus', function() {
          this.parentElement.classList.add('focused');
        });
        
        input.addEventListener('blur', function() {
          this.parentElement.classList.remove('focused');
          if (this.value) {
            this.parentElement.classList.add('has-value');
          } else {
            this.parentElement.classList.remove('has-value');
          }
        });
        
        // Check if input already has value on page load
        if (input.value) {
          input.parentElement.classList.add('has-value');
        }
      });

      // Add entrance animation
      document.querySelector('.form-container').style.animation = 'slideInUp 0.6s ease-out';

      // Dental Chart Functionality
      let dentalChart = {};
      try {
        dentalChart = JSON.parse(document.getElementById('dentalChartData').value || '{}');
      } catch (e) {
        dentalChart = {};
      }
      
      let currentTreatment = 'C';
      
      // Treatment selector
      document.querySelectorAll('.legend-item').forEach(item => {
        item.addEventListener('click', function() {
          document.querySelectorAll('.legend-item').forEach(i => i.classList.remove('active'));
          this.classList.add('active');
          currentTreatment = this.dataset.treatment;
        });
      });
      
      // Set default treatment
      document.querySelector('.legend-item').classList.add('active');
      
      // Load existing dental chart data
      Object.keys(dentalChart).forEach(toothNumber => {
        const toothElement = document.querySelector(`[data-number="${toothNumber}"] .tooth-circle`);
        if (toothElement) {
          toothElement.classList.add('marked');
          toothElement.textContent = dentalChart[toothNumber];
        }
      });
      
      // Tooth click functionality
      document.querySelectorAll('.tooth-circle').forEach(circle => {
        circle.addEventListener('click', function() {
          const tooth = this.parentElement;
          const toothNumber = tooth.dataset.number;
          
          if (dentalChart[toothNumber] === currentTreatment) {
            // Remove treatment if clicking the same treatment
            delete dentalChart[toothNumber];
            this.classList.remove('marked');
            this.textContent = '';
          } else {
            // Apply new treatment
            dentalChart[toothNumber] = currentTreatment;
            this.classList.add('marked');
            this.textContent = currentTreatment;
          }
          
          // Update hidden field
          document.getElementById('dentalChartData').value = JSON.stringify(dentalChart);
        });
      });
    });
  </script>
</body>
</html>