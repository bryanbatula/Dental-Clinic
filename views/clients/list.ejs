<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Clients List | Clinic Management</title>
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
  <div class="dashboard-wrapper">
    <aside class="dashboard-sidebar">
      <!-- Enhanced User Profile Section -->
      <div class="dashboard-user-profile">
        <div class="user-avatar">
          <i class="fas fa-user-md"></i>
        </div>
        <div class="user-details">
          <h3 class="user-name">Dr. <%= user.username %></h3>
          <p class="user-role">Clinic Administrator</p>
          <div class="user-status">
            <span class="status-indicator active"></span>
            <span class="status-text">Online</span>
          </div>
        </div>
      </div>
      
      <!-- Enhanced Navigation -->
      <nav class="dashboard-nav">
        <div class="nav-section">
          <span class="nav-section-title">Main</span>
          <a href="/dashboard" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-pie"></i>
            </div>
            <span class="nav-text">Dashboard</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Management</span>
          <a href="/clients" class="dashboard-nav-item active">
            <div class="nav-icon">
              <i class="fas fa-users"></i>
            </div>
            <span class="nav-text">Clients</span>
          </a>
          <a href="/appointments" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="far fa-calendar-alt"></i>
            </div>
            <span class="nav-text">Appointments</span>
          </a>
          <a href="/appointments/calendar" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-calendar-week"></i>
            </div>
            <span class="nav-text">Calendar</span>
          </a>
          <a href="/services/manage" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-tooth"></i>
            </div>
            <span class="nav-text">Services</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Tools</span>
          <a href="/reminders" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-bell"></i>
            </div>
            <span class="nav-text">Reminders</span>
          </a>
          <a href="/reports" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-line"></i>
            </div>
            <span class="nav-text">Analytics</span>
          </a>
        </div>
      </nav>
      
      <!-- Enhanced Logout Section -->
      <div class="dashboard-logout">
        <a href="/logout" class="dashboard-logout-btn">
          <i class="fas fa-sign-out-alt"></i>
          <span>Sign Out</span>
        </a>
      </div>
    </aside>

    <main class="dashboard-content">
      <!-- Enhanced Header with Breadcrumb -->
      <header class="dashboard-header">
        <div class="header-content">
          <div class="breadcrumb">
            <span class="breadcrumb-item">Clinic</span>
            <i class="fas fa-chevron-right"></i>
            <span class="breadcrumb-item current">Clients</span>
          </div>
          <h1 class="dashboard-title">
            <i class="fas fa-users title-icon"></i>
            Client Management
          </h1>
          <p class="dashboard-subtitle">Manage patient records, contact information, and medical history</p>
        </div>
        <div class="header-actions">
          <div class="current-time" id="currentTime">
            <i class="far fa-clock"></i>
            <span></span>
          </div>
          <a href="/clients/add" class="dashboard-btn primary">
            <i class="fas fa-user-plus"></i>
            <span>New Client</span>
          </a>
        </div>
      </header>

      <!-- Enhanced Statistics Section -->
      <section class="clients-stats-section">
        <div class="stats-grid">
          <div class="stat-card clients-stat">
            <div class="stat-icon">
              <i class="fas fa-users"></i>
            </div>
            <div class="stat-content">
              <div class="stat-value"><%= pagination.totalItems %></div>
              <div class="stat-label">Total Clients</div>
              <div class="stat-trend">
                <i class="fas fa-arrow-up"></i>
                <span>Active patients</span>
              </div>
            </div>
          </div>
          
          <div class="stat-card showing-stat">
            <div class="stat-icon">
              <i class="fas fa-eye"></i>
            </div>
            <div class="stat-content">
              <div class="stat-value"><%= clients.length %></div>
              <div class="stat-label">Showing Now</div>
              <div class="stat-trend">
                <i class="fas fa-list"></i>
                <span>Page <%= pagination.currentPage %> of <%= pagination.totalPages %></span>
              </div>
            </div>
          </div>
          
          <div class="stat-card recent-stat">
            <div class="stat-icon">
              <i class="fas fa-calendar-plus"></i>
            </div>
            <div class="stat-content">
              <div class="stat-value">0</div>
              <div class="stat-label">Added This Week</div>
              <div class="stat-trend">
                <i class="fas fa-clock"></i>
                <span>Recent activity</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Enhanced Table Section -->
      <section class="clients-table-section">
        <div class="section-header">
          <h2 class="section-title">
            <i class="fas fa-table"></i>
            Client Directory
          </h2>
          <p class="section-subtitle">Complete list of registered patients</p>
        </div>

        <div class="clients-table-wrapper">
          <!-- Enhanced Table Info Bar -->
          <div class="table-info-bar">
            <div class="table-stats">
              <span class="total-count">
                <i class="fas fa-users"></i>
                Total: <%= pagination.totalItems %> clients
              </span>
              <span class="page-info">
                Showing <%= clients.length > 0 ? ((pagination.currentPage - 1) * pagination.itemsPerPage + 1) : 0 %> 
                to <%= Math.min(pagination.currentPage * pagination.itemsPerPage, pagination.totalItems) %> 
                of <%= pagination.totalItems %> entries
              </span>
            </div>
            <div class="table-actions">
              <span class="entries-per-page">
                <i class="fas fa-list"></i>
                <%= pagination.itemsPerPage %> per page
              </span>
            </div>
          </div>

          <% if (clients && clients.length > 0) { %>
            <table class="clients-table enhanced">
              <thead>
                <tr>
                  <th><i class="fas fa-user"></i> Patient</th>
                  <th><i class="fas fa-phone"></i> Contact</th>
                  <th><i class="fas fa-envelope"></i> Email</th>
                  <th><i class="fas fa-birthday-cake"></i> Age</th>
                  <th><i class="fas fa-cogs"></i> Actions</th>
                </tr>
              </thead>
              <tbody>
                <% clients.forEach((client, index) => { %>
                  <tr class="client-row" style="animation: slideInUp 0.3s ease-out <%= index * 0.05 %>s both;">
                    <td class="client-info">
                      <div class="client-profile">
                        <div class="client-details">
                          <strong class="client-name"><%= client.name %></strong>
                        </div>
                      </div>
                    </td>
                    <td class="contact-info">
                      <div class="phone-number">
                        <i class="fas fa-phone-alt"></i>
                        <%= client.phone %>
                      </div>
                    </td>
                    <td class="email-info">
                      <div class="email-address">
                        <i class="fas fa-envelope"></i>
                        <%= client.email %>
                      </div>
                    </td>
                    <td class="age-info">
                      <% if (client.dob) { %>
                        <div class="age-display">
                          <span class="age-number"><%= Math.floor((new Date() - new Date(client.dob)) / (365.25 * 24 * 60 * 60 * 1000)) %></span>
                          <span class="age-label">years</span>
                        </div>
                        <div class="birth-date">
                          <%= new Date(client.dob).toLocaleDateString() %>
                        </div>
                      <% } else { %>
                        <span class="no-data">Not specified</span>
                      <% } %>
                    </td>
                    <td class="actions-cell">
                      <div class="action-buttons">
                        <a href="/clients/view/<%= client.id %>" class="action-btn view" title="View Details">
                          <i class="fas fa-eye"></i>
                        </a>
                        <a href="/clients/edit/<%= client.id %>" class="action-btn edit" title="Edit Client">
                          <i class="fas fa-edit"></i>
                        </a>
                        <button type="button" class="action-btn delete" title="Delete Client" onclick="showDeleteModal('<%= client.id %>', '<%= client.name %>')">
                          <i class="fas fa-trash"></i>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } else { %>
            <div class="no-data-state">
              <div class="no-data-content">
                <div class="no-data-icon">
                  <i class="fas fa-user-friends"></i>
                </div>
                <h3>No clients found</h3>
                <p>Start building your patient database by adding your first client to the system.</p>
                <a href="/clients/add" class="dashboard-btn primary">
                  <i class="fas fa-user-plus"></i>
                  Add First Client
                </a>
              </div>
            </div>
          <% } %>

          <!-- Enhanced Pagination Controls -->
          <% if (pagination.totalPages > 1) { %>
            <div class="pagination-wrapper">
              <div class="pagination-info">
                <span>Page <%= pagination.currentPage %> of <%= pagination.totalPages %></span>
              </div>
              <nav class="pagination-nav">
                <div class="pagination-controls">
                  <!-- First Page -->
                  <% if (pagination.currentPage > 1) { %>
                    <a href="/clients?page=1" class="pagination-btn first" title="First Page">
                      <i class="fas fa-angle-double-left"></i>
                    </a>
                  <% } else { %>
                    <span class="pagination-btn first disabled">
                      <i class="fas fa-angle-double-left"></i>
                    </span>
                  <% } %>

                  <!-- Previous Page -->
                  <% if (pagination.hasPrev) { %>
                    <a href="/clients?page=<%= pagination.currentPage - 1 %>" class="pagination-btn prev" title="Previous Page">
                      <i class="fas fa-angle-left"></i>
                    </a>
                  <% } else { %>
                    <span class="pagination-btn prev disabled">
                      <i class="fas fa-angle-left"></i>
                    </span>
                  <% } %>

                  <!-- Page Numbers -->
                  <div class="pagination-numbers">
                    <% 
                      let startPage = Math.max(1, pagination.currentPage - 2);
                      let endPage = Math.min(pagination.totalPages, pagination.currentPage + 2);
                      
                      if (endPage - startPage < 4) {
                        if (startPage === 1) {
                          endPage = Math.min(pagination.totalPages, startPage + 4);
                        } else {
                          startPage = Math.max(1, endPage - 4);
                        }
                      }
                    %>
                    
                    <% for (let i = startPage; i <= endPage; i++) { %>
                      <% if (i === pagination.currentPage) { %>
                        <span class="pagination-btn current"><%= i %></span>
                      <% } else { %>
                        <a href="/clients?page=<%= i %>" class="pagination-btn"><%= i %></a>
                      <% } %>
                    <% } %>
                  </div>

                  <!-- Next Page -->
                  <% if (pagination.hasNext) { %>
                    <a href="/clients?page=<%= pagination.currentPage + 1 %>" class="pagination-btn next" title="Next Page">
                      <i class="fas fa-angle-right"></i>
                    </a>
                  <% } else { %>
                    <span class="pagination-btn next disabled">
                      <i class="fas fa-angle-right"></i>
                    </span>
                  <% } %>

                  <!-- Last Page -->
                  <% if (pagination.currentPage < pagination.totalPages) { %>
                    <a href="/clients?page=<%= pagination.totalPages %>" class="pagination-btn last" title="Last Page">
                      <i class="fas fa-angle-double-right"></i>
                    </a>
                  <% } else { %>
                    <span class="pagination-btn last disabled">
                      <i class="fas fa-angle-double-right"></i>
                    </span>
                  <% } %>
                </div>
              </nav>
            </div>
          <% } %>
        </div>
      </section>
    </main>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="deleteModal" class="modal-overlay hidden">
    <div class="modal-content">
      <div class="modal-icon">
        <i class="fas fa-exclamation-triangle"></i>
      </div>
      <h3 class="modal-title">Delete Client</h3>
      <p class="modal-message">
        Are you sure you want to delete this client? This action cannot be undone and will also remove all associated appointment records.
      </p>
      <div class="modal-actions">
        <button class="modal-btn cancel" onclick="hideDeleteModal()">Cancel</button>
        <button class="modal-btn confirm" onclick="confirmDelete()">Delete Client</button>
      </div>
    </div>
  </div>

  <script>
    // Enhanced functionality
    document.addEventListener('DOMContentLoaded', function() {
      // Update current time
      function updateTime() {
        const now = new Date();
        const timeString = now.toLocaleString('en-US', {
          weekday: 'short',
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });
        const timeElement = document.querySelector('#currentTime span');
        if (timeElement) {
          timeElement.textContent = timeString;
        }
      }
      
      updateTime();
      setInterval(updateTime, 60000);
    });

    // Delete modal functionality
    let deleteClientId = null;
    let deleteClientName = null;

    function showDeleteModal(clientId, clientName) {
      deleteClientId = clientId;
      deleteClientName = clientName;
      document.querySelector('.modal-message').innerHTML = 
        `Are you sure you want to delete <strong>${clientName}</strong>? This action cannot be undone and will also remove all associated appointment records.`;
      document.getElementById('deleteModal').classList.remove('hidden');
    }

    function hideDeleteModal() {
      document.getElementById('deleteModal').classList.add('hidden');
      deleteClientId = null;
      deleteClientName = null;
    }

    function confirmDelete() {
      if (deleteClientId) {
        // Create a form to submit the delete request
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/clients/delete/${deleteClientId}`;
        
        // Add CSRF token if needed
        const csrfInput = document.createElement('input');
        csrfInput.type = 'hidden';
        csrfInput.name = '_method';
        csrfInput.value = 'DELETE';
        form.appendChild(csrfInput);
        
        document.body.appendChild(form);
        form.submit();
      }
    }

    // Close modal on escape key
    document.addEventListener('keydown', function(event) {
      if (event.key === 'Escape') {
        hideDeleteModal();
      }
    });

    // Close modal on background click
    document.getElementById('deleteModal').addEventListener('click', function(event) {
      if (event.target === this) {
        hideDeleteModal();
      }
    });
  </script>
</body>
</html> 