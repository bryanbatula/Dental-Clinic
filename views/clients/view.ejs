<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= client.name %> - Client Details | Clinic Management</title>
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
  <div class="dashboard-wrapper">
    <aside class="dashboard-sidebar">
      <!-- Enhanced User Profile Section -->
      <div class="dashboard-user-profile">
        <div class="user-avatar">
          <i class="fas fa-user-md"></i>
        </div>
        <div class="user-details">
          <h3 class="user-name"><%= user.username %></h3>
          <p class="user-role">Clinic Administrator</p>
          <div class="user-status">
            <span class="status-indicator active"></span>
            <span class="status-text">Online</span>
          </div>
        </div>
      </div>
      
      <!-- Enhanced Navigation -->
      <nav class="dashboard-nav">
        <div class="nav-section">
          <span class="nav-section-title">Main</span>
          <a href="/dashboard" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-pie"></i>
            </div>
            <span class="nav-text">Dashboard</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Management</span>
          <a href="/clients" class="dashboard-nav-item active">
            <div class="nav-icon">
              <i class="fas fa-users"></i>
            </div>
            <span class="nav-text">Clients</span>
          </a>
          <a href="/appointments" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="far fa-calendar-alt"></i>
            </div>
            <span class="nav-text">Appointments</span>
          </a>
          <a href="/treatments" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-procedures"></i>
            </div>
            <span class="nav-text">Treatments</span>
          </a>
          <a href="/appointments/calendar" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-calendar-week"></i>
            </div>
            <span class="nav-text">Calendar</span>
          </a>
          <a href="/services/manage" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-tooth"></i>
            </div>
            <span class="nav-text">Services</span>
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Tools</span>
          <a href="/reminders" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-bell"></i>
            </div>
            <span class="nav-text">Reminders</span>
          </a>
          <a href="/reports" class="dashboard-nav-item">
            <div class="nav-icon">
              <i class="fas fa-chart-line"></i>
            </div>
            <span class="nav-text">Analytics</span>
          </a>
        </div>
      </nav>
      
      <!-- Enhanced Logout Section -->
      <div class="dashboard-logout">
        <a href="/logout" class="dashboard-logout-btn">
          <i class="fas fa-sign-out-alt"></i>
          <span>Sign Out</span>
        </a>
      </div>
    </aside>

    <main class="dashboard-content">
      <!-- Enhanced Header with Breadcrumb -->
      <header class="dashboard-header">
        <div class="header-content">
          <div class="breadcrumb">
            <span class="breadcrumb-item">Clinic</span>
            <i class="fas fa-chevron-right"></i>
            <span class="breadcrumb-item">
              <a href="/clients" style="color: #6b7280; text-decoration: none;">Clients</a>
            </span>
            <i class="fas fa-chevron-right"></i>
            <span class="breadcrumb-item current"><%= client.name %></span>
          </div>
          <h1 class="dashboard-title">
            <i class="fas fa-user-circle title-icon"></i>
            Client Profile
          </h1>
          <p class="dashboard-subtitle">Comprehensive patient information and appointment history</p>
        </div>
        <div class="header-actions">
          <div class="current-time" id="currentTime">
            <i class="far fa-clock"></i>
            <span></span>
          </div>
          <a href="/clients/edit/<%= client.id %>" class="dashboard-btn primary">
            <i class="fas fa-edit"></i>
            <span>Edit Client</span>
          </a>
          <a href="/appointments/add?client_id=<%= client.id %>" class="dashboard-btn secondary">
            <i class="fas fa-calendar-plus"></i>
            <span>New Appointment</span>
          </a>
          <a href="/clients" class="dashboard-btn">
            <i class="fas fa-arrow-left"></i>
            <span>Back to Clients</span>
          </a>
        </div>
      </header>

      <!-- Enhanced Client Information Section -->
      <section class="client-profile-section">
        <div class="client-profile-card">
          <!-- Enhanced Client Header -->
          <div class="client-header">
            <div class="client-avatar-large">
              <%= client.name.charAt(0).toUpperCase() %>
            </div>
            <div class="client-title-section">
              <h2 class="client-name"><%= client.name %></h2>
              <p class="client-id">Patient ID: #<%= client.id %></p>
              <div class="client-badges">
                <span class="status-badge active">
                  <i class="fas fa-heart-pulse"></i>
                  Active Patient
                </span>
                <% if (client.medical_history) { %>
                  <span class="info-badge medical">
                    <i class="fas fa-notes-medical"></i>
                    Medical History Available
                  </span>
                <% } %>
              </div>
            </div>
            <div class="client-stats">
              <div class="stat-item">
                <span class="stat-value" id="totalAppointments">
                  <%= appointments ? appointments.length : 0 %>
                </span>
                <span class="stat-label">Total Appointments</span>
              </div>
              <div class="stat-item">
                <span class="stat-value" id="completedAppointments">
                  <%= appointments ? appointments.filter(apt => apt.status.toLowerCase() === 'completed').length : 0 %>
                </span>
                <span class="stat-label">Completed</span>
              </div>
            </div>
          </div>

          <!-- Enhanced Information Grid -->
          <div class="client-info-grid">
            <!-- Contact Information Card -->
            <div class="info-card contact-info">
              <div class="info-card-header">
                <div class="card-icon contact">
                  <i class="fas fa-address-book"></i>
                </div>
                <h3>Contact Information</h3>
                <div class="card-badge verified">
                  <i class="fas fa-shield-check"></i>
                  Verified
                </div>
              </div>
              <div class="info-card-content">
                <div class="info-item">
                  <div class="info-icon">
                    <i class="fas fa-envelope"></i>
                  </div>
                  <div class="info-details">
                    <label>Email Address</label>
                    <% if (client.email) { %>
                      <span class="copyable" data-copy="<%= client.email %>"><%= client.email %></span>
                      <button class="copy-btn" title="Copy Email">
                        <i class="fas fa-copy"></i>
                      </button>
                    <% } else { %>
                      <span class="no-data">Not specified</span>
                    <% } %>
                  </div>
                </div>
                <div class="info-item">
                  <div class="info-icon">
                    <i class="fas fa-phone"></i>
                  </div>
                  <div class="info-details">
                    <label>Phone Number</label>
                    <% if (client.phone) { %>
                      <span class="copyable" data-copy="<%= client.phone %>"><%= client.phone %></span>
                      <button class="copy-btn" title="Copy Phone">
                        <i class="fas fa-copy"></i>
                      </button>
                    <% } else { %>
                      <span class="no-data">Not specified</span>
                    <% } %>
                  </div>
                </div>
                <% if (client.address) { %>
                  <div class="info-item">
                    <div class="info-icon">
                      <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <div class="info-details">
                      <label>Address</label>
                      <span class="copyable" data-copy="<%= client.address %>"><%= client.address %></span>
                      <button class="copy-btn" title="Copy Address">
                        <i class="fas fa-copy"></i>
                      </button>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>

            <!-- Personal Information Card -->
            <div class="info-card personal-info">
              <div class="info-card-header">
                <div class="card-icon personal">
                  <i class="fas fa-user"></i>
                </div>
                <h3>Personal Details</h3>
                <div class="card-action">
                  <button class="action-btn small edit" title="Quick Edit">
                    <i class="fas fa-pen"></i>
                  </button>
                </div>
              </div>
              <div class="info-card-content">
                <% if (client.dob) { %>
                  <div class="info-item">
                    <div class="info-icon">
                      <i class="fas fa-birthday-cake"></i>
                    </div>
                    <div class="info-details">
                      <label>Date of Birth</label>
                      <span><%= new Date(client.dob).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                    </div>
                  </div>
                  <div class="info-item age-display">
                    <div class="info-icon">
                      <i class="fas fa-calendar-alt"></i>
                    </div>
                    <div class="info-details">
                      <label>Age</label>
                      <span class="age-value"><%= Math.floor((new Date() - new Date(client.dob)) / (365.25 * 24 * 60 * 60 * 1000)) %> years old</span>
                    </div>
                  </div>
                <% } else { %>
                  <div class="info-item">
                    <div class="info-icon">
                      <i class="fas fa-birthday-cake"></i>
                    </div>
                    <div class="info-details">
                      <label>Date of Birth</label>
                      <span class="no-data">Not specified</span>
                    </div>
                  </div>
                <% } %>
                <div class="info-item">
                  <div class="info-icon">
                    <i class="fas fa-clock"></i>
                  </div>
                  <div class="info-details">
                    <label>Registration Date</label>
                    <span><%= new Date(client.created_at || Date.now()).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                  </div>
                </div>
                <div class="info-item">
                  <div class="info-icon">
                    <i class="fas fa-user-clock"></i>
                  </div>
                  <div class="info-details">
                    <label>Patient Since</label>
                    <span id="patientDuration"></span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Professional Information Card -->
            <div class="info-card professional-info">
              <div class="info-card-header">
                <div class="card-icon professional">
                  <i class="fas fa-briefcase"></i>
                </div>
                <h3>Professional Information</h3>
              </div>
              <div class="info-card-content">
                <% if (client.occupation) { %>
                  <div class="info-item">
                    <div class="info-icon">
                      <i class="fas fa-briefcase"></i>
                    </div>
                    <div class="info-details">
                      <label>Occupation</label>
                      <span><%= client.occupation %></span>
                    </div>
                  </div>
                <% } else { %>
                  <div class="info-item">
                    <div class="info-icon">
                      <i class="fas fa-briefcase"></i>
                    </div>
                    <div class="info-details">
                      <label>Occupation</label>
                      <span class="no-data">Not specified</span>
                    </div>
                  </div>
                <% } %>
                
                <% if (client.referred_by) { %>
                  <div class="info-item">
                    <div class="info-icon">
                      <i class="fas fa-user-friends"></i>
                    </div>
                    <div class="info-details">
                      <label>Referred By</label>
                      <span><%= client.referred_by %></span>
                    </div>
                  </div>
                <% } else { %>
                  <div class="info-item">
                    <div class="info-icon">
                      <i class="fas fa-user-friends"></i>
                    </div>
                    <div class="info-details">
                      <label>Referred By</label>
                      <span class="no-data">Not specified</span>
                    </div>
                  </div>
                <% } %>
                
                <!-- <% if (client.remarks) { %>
                  <div class="info-item">
                    <div class="info-icon">
                      <i class="fas fa-star"></i>
                    </div>
                    <div class="info-details">
                      <label>Patient Behavior</label>
                      <span class="remarks-badge"><%= client.remarks %></span>
                    </div>
                  </div>
                <% } %> -->
              </div>
            </div>
          </div>

          <!-- Dental Chart Section -->
          <% 
            let dentalChart = {};
            try {
              dentalChart = typeof client.dental_chart === 'string' ? JSON.parse(client.dental_chart || '{}') : client.dental_chart || {};
            } catch(e) {
              dentalChart = {};
            }
          %>
          <% if (Object.keys(dentalChart).length > 0) { %>
            <div class="dental-chart-section">
              <div class="section-divider">
                <span class="divider-text">
                  <i class="fas fa-tooth"></i>
                  Dental Chart
                </span>
              </div>
              
              <div class="dental-chart-display">
                <!-- Treatment Legend -->
                <div class="treatment-legend-display">
                  <div class="legend-item"><span class="legend-symbol c">C</span><span>Filling</span></div>
                  <div class="legend-item"><span class="legend-symbol ii">II</span><span>Extraction</span></div>
                  <div class="legend-item"><span class="legend-symbol x">X</span><span>Missing</span></div>
                  <div class="legend-item"><span class="legend-symbol lc">LC</span><span>Composite</span></div>
                  <div class="legend-item"><span class="legend-symbol am">AM</span><span>Amalgam</span></div>
                  <div class="legend-item"><span class="legend-symbol se">Se</span><span>Sealants</span></div>
                </div>

                <!-- Dental Chart Display -->
                <div class="dental-chart-grid">
                  <!-- Upper Baby Teeth -->
                  <div class="teeth-row upper-baby">
                    <div class="teeth-numbers">
                      <span>55</span><span>54</span><span>53</span><span>52</span><span>51</span>
                      <span>61</span><span>62</span><span>63</span><span>64</span><span>65</span>
                    </div>
                    <div class="teeth-visual">
                      <% ['55', '54', '53', '52', '51', '61', '62', '63', '64', '65'].forEach(toothNum => { %>
                        <div class="tooth-display <%= dentalChart[toothNum] ? 'has-treatment' : '' %>" data-number="<%= toothNum %>">
                          <div class="tooth-circle">
                            <%= dentalChart[toothNum] || '' %>
                          </div>
                        </div>
                      <% }); %>
                    </div>
                  </div>

                  <!-- Adult Upper Teeth -->
                  <div class="teeth-row adult-upper">
                    <div class="teeth-numbers">
                      <span>18</span><span>17</span><span>16</span><span>15</span><span>14</span><span>13</span><span>12</span><span>11</span>
                      <span>21</span><span>22</span><span>23</span><span>24</span><span>25</span><span>26</span><span>27</span><span>28</span>
                    </div>
                    <div class="teeth-visual">
                      <% ['18', '17', '16', '15', '14', '13', '12', '11', '21', '22', '23', '24', '25', '26', '27', '28'].forEach(toothNum => { %>
                        <div class="tooth-display <%= dentalChart[toothNum] ? 'has-treatment' : '' %>" data-number="<%= toothNum %>">
                          <div class="tooth-circle">
                            <%= dentalChart[toothNum] || '' %>
                          </div>
                        </div>
                      <% }); %>
                    </div>
                  </div>

                  <!-- Adult Lower Teeth -->
                  <div class="teeth-row adult-lower">
                    <div class="teeth-visual">
                      <% ['48', '47', '46', '45', '44', '43', '42', '41', '31', '32', '33', '34', '35', '36', '37', '38'].forEach(toothNum => { %>
                        <div class="tooth-display <%= dentalChart[toothNum] ? 'has-treatment' : '' %>" data-number="<%= toothNum %>">
                          <div class="tooth-circle">
                            <%= dentalChart[toothNum] || '' %>
                          </div>
                        </div>
                      <% }); %>
                    </div>
                    <div class="teeth-numbers">
                      <span>48</span><span>47</span><span>46</span><span>45</span><span>44</span><span>43</span><span>42</span><span>41</span>
                      <span>31</span><span>32</span><span>33</span><span>34</span><span>35</span><span>36</span><span>37</span><span>38</span>
                    </div>
                  </div>

                  <!-- Lower Baby Teeth -->
                  <div class="teeth-row lower-baby">
                    <div class="teeth-visual">
                      <% ['85', '84', '83', '82', '81', '71', '72', '73', '74', '75'].forEach(toothNum => { %>
                        <div class="tooth-display <%= dentalChart[toothNum] ? 'has-treatment' : '' %>" data-number="<%= toothNum %>">
                          <div class="tooth-circle">
                            <%= dentalChart[toothNum] || '' %>
                          </div>
                        </div>
                      <% }); %>
                    </div>
                    <div class="teeth-numbers">
                      <span>85</span><span>84</span><span>83</span><span>82</span><span>81</span>
                      <span>71</span><span>72</span><span>73</span><span>74</span><span>75</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% } %>

          <!-- Enhanced Medical Information Section -->
          <div class="medical-info-section">
            <div class="section-divider">
              <span class="divider-text">
                <i class="fas fa-notes-medical"></i>
                Medical Information
              </span>
            </div>

            <div class="medical-cards-grid">
              <!-- Present Oral Complaint -->
              <% if (client.present_oral_complaint) { %>
                <div class="medical-card">
                  <div class="medical-card-header">
                    <div class="card-icon complaint">
                      <i class="fas fa-exclamation-triangle"></i>
                    </div>
                    <h3>Present Oral Complaint</h3>
                  </div>
                  <div class="medical-card-content">
                    <div class="medical-text">
                      <%= client.present_oral_complaint %>
                    </div>
                  </div>
                </div>
              <% } %>

              <!-- Comprehensive Medical Information -->
              <% 
                let medicalInfo = {};
                try {
                  medicalInfo = typeof client.medical_information === 'string' ? JSON.parse(client.medical_information || '{}') : client.medical_information || {};
                } catch(e) {
                  medicalInfo = {};
                }
              %>
              <% if (Object.keys(medicalInfo).length > 0 || medicalInfo.underPhysicianCare || medicalInfo.conditions) { %>
                <div class="medical-card">
                  <div class="medical-card-header">
                    <div class="card-icon medical">
                      <i class="fas fa-heartbeat"></i>
                    </div>
                    <h3>Medical Information</h3>
                  </div>
                  <div class="medical-card-content">
                    <% if (medicalInfo.underPhysicianCare === 'yes') { %>
                      <div class="medical-item">
                        <strong>Under Physician Care:</strong> Yes
                        <% if (medicalInfo.physicianName) { %>
                          <div class="physician-details">
                            <span>Dr. <%= medicalInfo.physicianName %></span>
                            <% if (medicalInfo.physicianAddress) { %><br><span><%= medicalInfo.physicianAddress %></span><% } %>
                            <% if (medicalInfo.physicianPhone) { %><br><span><%= medicalInfo.physicianPhone %></span><% } %>
                          </div>
                        <% } %>
                      </div>
                    <% } %>
                    
                    <% if (medicalInfo.hospitalized === 'yes') { %>
                      <div class="medical-item">
                        <strong>Previous Hospitalization:</strong> Yes
                      </div>
                    <% } %>
                    
                    <% if (medicalInfo.conditions && medicalInfo.conditions.length > 0) { %>
                      <div class="medical-item">
                        <strong>Medical Conditions:</strong>
                        <div class="conditions-list">
                          <% medicalInfo.conditions.forEach(condition => { %>
                            <span class="condition-badge"><%= condition.replace('_', ' ') %></span>
                          <% }); %>
                        </div>
                      </div>
                    <% } %>
                  </div>
                </div>
              <% } %>

              <!-- Dental Information -->
              <% 
                let dentalInfo = {};
                try {
                  dentalInfo = typeof client.dental_information === 'string' ? JSON.parse(client.dental_information || '{}') : client.dental_information || {};
                } catch(e) {
                  dentalInfo = {};
                }
              %>
              <% if (Object.keys(dentalInfo).length > 0 || dentalInfo.dentalHistory || dentalInfo.jawProblems) { %>
                <div class="medical-card">
                  <div class="medical-card-header">
                    <div class="card-icon dental">
                      <i class="fas fa-tooth"></i>
                    </div>
                    <h3>Dental Information</h3>
                  </div>
                  <div class="medical-card-content">
                    <% if (dentalInfo.dentalHistory && dentalInfo.dentalHistory.length > 0) { %>
                      <div class="medical-item">
                        <strong>Previous Dental Treatments:</strong>
                        <div class="treatments-list">
                          <% dentalInfo.dentalHistory.forEach(treatment => { %>
                            <span class="treatment-badge"><%= treatment.replace('_', ' ') %></span>
                          <% }); %>
                        </div>
                      </div>
                    <% } %>
                    
                    <% if (dentalInfo.jawProblems && dentalInfo.jawProblems.length > 0) { %>
                      <div class="medical-item">
                        <strong>Jaw Problems:</strong>
                        <div class="problems-list">
                          <% dentalInfo.jawProblems.forEach(problem => { %>
                            <span class="problem-badge"><%= problem.replace('_', ' ') %></span>
                          <% }); %>
                        </div>
                      </div>
                    <% } %>
                  </div>
                </div>
              <% } %>

              <!-- Previous Dental Care -->
              <% if (client.previous_dental_care || client.clinic_dentist) { %>
                <div class="medical-card">
                  <div class="medical-card-header">
                    <div class="card-icon history">
                      <i class="fas fa-history"></i>
                    </div>
                    <h3>Previous Dental Care</h3>
                  </div>
                  <div class="medical-card-content">
                    <% if (client.previous_dental_care) { %>
                      <div class="medical-item">
                        <strong>Treatment History:</strong>
                        <div class="medical-text">
                          <%= client.previous_dental_care %>
                        </div>
                      </div>
                    <% } %>
                    <% if (client.clinic_dentist) { %>
                      <div class="medical-item">
                        <strong>Previous Clinic/Dentist:</strong>
                        <span><%= client.clinic_dentist %></span>
                      </div>
                    <% } %>
                  </div>
                </div>
              <% } %>

              <!-- Traditional Medical History -->
              <% if (client.medical_history) { %>
                <div class="medical-card">
                  <div class="medical-card-header">
                    <div class="card-icon medical">
                      <i class="fas fa-notes-medical"></i>
                    </div>
                    <h3>Additional Medical History</h3>
                    <div class="card-actions">
                      <button class="action-btn small view" title="Expand">
                        <i class="fas fa-expand"></i>
                      </button>
                    </div>
                  </div>
                  <div class="medical-card-content">
                    <div class="medical-text">
                      <%= client.medical_history %>
                    </div>
                  </div>
                </div>
              <% } %>

              <!-- Additional Notes -->
              <% if (client.notes) { %>
                <div class="medical-card">
                  <div class="medical-card-header">
                    <div class="card-icon notes">
                      <i class="fas fa-sticky-note"></i>
                    </div>
                    <h3>Additional Notes</h3>
                    <div class="card-actions">
                      <button class="action-btn small edit" title="Edit Notes">
                        <i class="fas fa-edit"></i>
                      </button>
                    </div>
                  </div>
                  <div class="medical-card-content">
                    <div class="medical-text">
                      <%= client.notes %>
                    </div>
                  </div>
                </div>
              <% } %>
            </div>
          </div>

          
        </div>
      </section>



      <!-- Treatment Records and Billing Section -->
      <section class="treatments-section">
        <div class="section-header">
          <div class="header-left">
            <h2 class="section-title">
              <i class="fas fa-tooth"></i>
              Treatment Records & Billing
            </h2>
            <p class="section-subtitle">Complete treatment history with financial tracking</p>
          </div>
          <div class="header-right">
            <a href="/treatments/add?client_id=<%= client.id %>" class="dashboard-btn primary">
              <i class="fas fa-plus"></i>
              Add Treatment
            </a>
            <a href="/treatments" class="dashboard-btn">
              <i class="fas fa-list"></i>
              All Treatments
            </a>
          </div>
        </div>

        <!-- Financial Summary Cards -->
        <div class="financial-summary-cards">
          <div class="summary-card" id="totalTreatments">
            <div class="card-icon treatments">
              <i class="fas fa-tooth"></i>
            </div>
            <div class="card-content">
              <span class="card-value">0</span>
              <span class="card-label">Total Treatments</span>
            </div>
          </div>
          <div class="summary-card" id="totalCharges">
            <div class="card-icon charges">
              <i class="fas fa-dollar-sign"></i>
            </div>
            <div class="card-content">
              <span class="card-value">$0.00</span>
              <span class="card-label">Total Charges</span>
            </div>
          </div>
          <div class="summary-card" id="totalPaid">
            <div class="card-icon paid">
              <i class="fas fa-check-circle"></i>
            </div>
            <div class="card-content">
              <span class="card-value">$0.00</span>
              <span class="card-label">Total Paid</span>
            </div>
          </div>
          <div class="summary-card" id="totalBalance">
            <div class="card-icon balance">
              <i class="fas fa-exclamation-circle"></i>
            </div>
            <div class="card-content">
              <span class="card-value">$0.00</span>
              <span class="card-label">Outstanding Balance</span>
            </div>
          </div>
        </div>

        <!-- Treatment Records Table -->
        <div class="treatments-table-container" id="treatmentsContainer">
          <div class="loading-placeholder">
            <i class="fas fa-spinner fa-spin"></i>
            <span>Loading treatment records...</span>
          </div>
        </div>
      </section>
    </main>
  </div>

  <!-- Toast Notification -->
  <div id="toast" class="toast hidden">
    <div class="toast-content">
      <i class="toast-icon"></i>
      <span class="toast-message"></span>
    </div>
  </div>

  <script>
    // Enhanced functionality
    document.addEventListener('DOMContentLoaded', function() {
      // Load treatment records for this client
      loadTreatmentRecords();

      // Update current time
      function updateTime() {
        const now = new Date();
        const timeString = now.toLocaleString('en-US', {
          weekday: 'short',
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });
        const timeElement = document.querySelector('#currentTime span');
        if (timeElement) {
          timeElement.textContent = timeString;
        }
      }
      
      updateTime();
      setInterval(updateTime, 60000);

      // Calculate patient duration
      const registrationDate = new Date('<%= client.created_at || Date.now() %>');
      const now = new Date();
      const diffTime = Math.abs(now - registrationDate);
      const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
      const diffYears = Math.floor(diffDays / 365);
      const remainingDays = diffDays % 365;
      const diffMonths = Math.floor(remainingDays / 30);
      
      let durationText = '';
      if (diffYears > 0) {
        durationText = `${diffYears} year${diffYears > 1 ? 's' : ''}`;
        if (diffMonths > 0) {
          durationText += `, ${diffMonths} month${diffMonths > 1 ? 's' : ''}`;
        }
      } else if (diffMonths > 0) {
        durationText = `${diffMonths} month${diffMonths > 1 ? 's' : ''}`;
      } else {
        durationText = `${diffDays} day${diffDays > 1 ? 's' : ''}`;
      }
      
      const patientDurationElement = document.querySelector('#patientDuration');
      if (patientDurationElement) {
        patientDurationElement.textContent = durationText;
      }

      // Copy functionality
      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          const copyText = this.previousElementSibling.dataset.copy;
          navigator.clipboard.writeText(copyText).then(() => {
            showToast('Copied to clipboard!', 'success');
            this.innerHTML = '<i class="fas fa-check"></i>';
            setTimeout(() => {
              this.innerHTML = '<i class="fas fa-copy"></i>';
            }, 2000);
          });
        });
      });

      // Add entrance animations with staggered timing
      const animatedElements = document.querySelectorAll('.animate-slide-in');
      animatedElements.forEach((element, index) => {
        element.style.animationDelay = `${index * 0.1}s`;
      });

      // Smooth scroll to sections
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
          }
        });
      });
    });

    // Toast notification function
    function showToast(message, type = 'info') {
      const toast = document.getElementById('toast');
      const icon = toast.querySelector('.toast-icon');
      const messageSpan = toast.querySelector('.toast-message');
      
      // Set icon based on type
      const icons = {
        success: 'fas fa-check-circle',
        error: 'fas fa-exclamation-circle',
        warning: 'fas fa-exclamation-triangle',
        info: 'fas fa-info-circle'
      };
      
      icon.className = `toast-icon ${icons[type] || icons.info}`;
      messageSpan.textContent = message;
      toast.className = `toast ${type}`;
      
      // Show toast
      setTimeout(() => toast.classList.add('show'), 100);
      
      // Hide toast after 3 seconds
      setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => toast.classList.add('hidden'), 300);
      }, 3000);
    }

    // Load treatment records for the client
    function loadTreatmentRecords() {
      const clientId = '<%= client.id %>';
      
      fetch(`/treatments/client/${clientId}`)
        .then(response => response.json())
        .then(data => {
          updateFinancialSummary(data.summary);
          renderTreatmentRecords(data.treatments);
        })
        .catch(error => {
          console.error('Error loading treatment records:', error);
          document.getElementById('treatmentsContainer').innerHTML = 
            '<div class="error-state"><i class="fas fa-exclamation-triangle"></i><span>Failed to load treatment records</span></div>';
        });
    }

    // Update financial summary cards
    function updateFinancialSummary(summary) {
      document.querySelector('#totalTreatments .card-value').textContent = summary.totalTreatments;
      document.querySelector('#totalCharges .card-value').textContent = '$' + summary.totalCharges.toFixed(2);
      document.querySelector('#totalPaid .card-value').textContent = '$' + summary.totalPaid.toFixed(2);
      document.querySelector('#totalBalance .card-value').textContent = '$' + summary.totalBalance.toFixed(2);
      
      // Update balance card styling based on amount
      const balanceCard = document.getElementById('totalBalance');
      if (summary.totalBalance > 0) {
        balanceCard.classList.add('has-balance');
        balanceCard.querySelector('.card-icon i').className = 'fas fa-exclamation-circle';
      } else {
        balanceCard.classList.add('paid-full');
        balanceCard.querySelector('.card-icon i').className = 'fas fa-check-circle';
      }
    }

    // Render treatment records table
    function renderTreatmentRecords(treatments) {
      const container = document.getElementById('treatmentsContainer');
      
      if (!treatments || treatments.length === 0) {
        container.innerHTML = `
          <div class="no-data-state">
            <div class="no-data-content">
              <div class="no-data-icon">
                <i class="fas fa-tooth"></i>
              </div>
              <h3>No treatment records found</h3>
              <p>No treatments have been recorded for this patient yet.</p>
              <a href="/treatments/add?client_id=<%= client.id %>" class="dashboard-btn primary">
                <i class="fas fa-plus"></i>
                Add First Treatment
              </a>
            </div>
          </div>
        `;
        return;
      }

      const tableHTML = `
        <table class="treatments-table">
          <thead>
            <tr>
              <th><i class="fas fa-calendar"></i> Date</th>
              <th><i class="fas fa-tooth"></i> Tooth #</th>
              <th><i class="fas fa-notes-medical"></i> Description</th>
              <th><i class="fas fa-user-md"></i> Dentist</th>
              <th><i class="fas fa-dollar-sign"></i> Charge</th>
              <th><i class="fas fa-credit-card"></i> Paid</th>
              <th><i class="fas fa-balance-scale"></i> Balance</th>
              <th><i class="fas fa-cogs"></i> Actions</th>
            </tr>
          </thead>
          <tbody>
            ${treatments.map(treatment => `
              <tr class="treatment-row ${treatment.balance > 0 ? 'has-balance' : 'paid'}">
                <td class="date-cell">
                  ${new Date(treatment.date_performed).toLocaleDateString()}
                </td>
                <td class="tooth-cell">
                  ${treatment.tooth_number || '-'}
                </td>
                <td class="description-cell">
                  <div class="description-text" title="${treatment.description}">
                    ${treatment.description.length > 40 ? 
                      treatment.description.substring(0, 40) + '...' : 
                      treatment.description}
                  </div>
                </td>
                <td class="dentist-cell">
                  ${treatment.dentist || '-'}
                </td>
                <td class="amount-cell">
                  $${treatment.charge.toFixed(2)}
                </td>
                <td class="amount-cell paid">
                  $${treatment.paid.toFixed(2)}
                </td>
                <td class="amount-cell ${treatment.balance > 0 ? 'balance' : 'paid'}">
                  $${treatment.balance.toFixed(2)}
                </td>
                <td class="actions-cell">
                  <div class="action-buttons">
                    <a href="/treatments/view/${treatment.id}" class="action-btn view" title="View Details">
                      <i class="fas fa-eye"></i>
                    </a>
                    <a href="/treatments/edit/${treatment.id}" class="action-btn edit" title="Edit">
                      <i class="fas fa-edit"></i>
                    </a>
                    ${treatment.balance > 0 ? `
                      <button onclick="showQuickPayment(${treatment.id}, ${treatment.balance})" 
                              class="action-btn pay" title="Add Payment">
                        <i class="fas fa-dollar-sign"></i>
                      </button>
                    ` : ''}
                  </div>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      `;
      
      container.innerHTML = tableHTML;
    }

    // Quick payment modal
    function showQuickPayment(treatmentId, balance) {
      const amount = prompt(`Add payment for treatment (Max: $${balance.toFixed(2)}):`);
      if (amount && parseFloat(amount) > 0 && parseFloat(amount) <= balance) {
        const notes = prompt('Payment notes (optional):') || '';
        
        fetch(`/treatments/payment/${treatmentId}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
          },
          body: `amount=${amount}&notes=${encodeURIComponent(notes)}`
        })
        .then(response => {
          if (response.ok) {
            showToast('Payment recorded successfully!', 'success');
            loadTreatmentRecords(); // Refresh the table
          } else {
            throw new Error('Payment failed');
          }
        })
        .catch(error => {
          showToast('Failed to record payment', 'error');
          console.error('Payment error:', error);
        });
      }
    }
  </script>
</body>
</html> 